---
const trustSignals = [
	"26+ Years Experience",
	"Millions Recovered",
	"Available 24/7",
	"Free Consultation",
];

const phoneDisplay = "(702) 222-2115";
const phoneHref = "tel:7022222115";
---

<section class="bg-brand-navy text-white" aria-labelledby="hero-heading">
	<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-28">
		<div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12">
		<div class="text-center lg:text-left">
		<h1
			id="hero-heading"
			class="text-3xl font-extrabold leading-tight tracking-tight text-balance sm:text-4xl md:text-5xl lg:text-6xl"
		>
			Hurt In An Accident? You Deserve Better.
		</h1>

		<div class="mx-auto mt-6 h-1 w-24 rounded-full bg-brand-gold lg:mx-0"></div>

		<p class="mt-6 text-lg font-medium text-balance text-brand-gold sm:text-xl lg:text-2xl">
			Better Representation. Better Recovery. It's Better With Blank.
		</p>

		<p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-pretty text-white/80 sm:text-lg lg:mx-0">
			For over 26 years, Eric Blank Injury Attorneys has fought Las Vegas insurance
			companies to get injury victims the compensation they truly deserve. No fees
			unless we win your case.
		</p>

		<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:mt-10 sm:flex-row lg:justify-start">
			<a
				href="/contact"
				class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
			>
				Free Case Review
			</a>
			<a
				href={phoneHref}
				class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
			>
				<svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path
						fill-rule="evenodd"
						clip-rule="evenodd"
						d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z"
					/>
				</svg>
				<span>{phoneDisplay}</span>
			</a>
		</div>

		<ul
			class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:mt-10 sm:text-sm lg:mx-0 lg:justify-start"
		>
			{
				trustSignals.map((signal, index) => (
					<li
						class:list={[
							index > 0 &&
								"before:mx-2.5 before:text-white/30 before:content-['•'] sm:before:mx-3",
						]}
					>
						{signal}
					</li>
				))
			}
		</ul>
		</div>
		<div class="flex justify-center lg:justify-end">
			<img
				src="/eric-blank-home.jpg"
				alt="Attorney Eric Blank"
				width="1264"
				height="842"
				class="w-full max-w-md rounded-xl object-cover shadow-2xl"
			/>
		</div>
		</div>
	</div>
</section>
