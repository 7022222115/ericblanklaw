---
const navLinks = [
	{ label: "Home", href: "/" },
	{ label: "About", href: "/about" },
	{ label: "Practice Areas", href: "/practice-areas" },
	{ label: "Results", href: "/results" },
	{ label: "Reviews", href: "/reviews" },
	{ label: "Blog", href: "/blog" },
	{ label: "Contact", href: "/contact" },
];

const phoneDisplay = "(702) 222-2115";
const phoneHref = "tel:7022222115";
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white">
	<div class="relative mx-auto flex max-w-7xl items-center justify-between gap-2 px-4 py-4 sm:gap-4 sm:px-6 lg:px-8">
		<!-- Logo -->
		<a href="/" class="flex shrink-0 items-center" aria-label="Eric Blank Injury Attorneys — home">
			<img
				src="/Eric_Blank_Injury_Attorneys_Logo.png"
				alt="Eric Blank Injury Attorneys"
				width="2240"
				height="541"
				class="h-11 w-auto lg:h-14"
			/>
		</a>

		<!-- Desktop navigation -->
		<nav
			class="hidden md:flex md:flex-1 md:items-center md:justify-center md:gap-x-3 lg:gap-x-6 xl:gap-x-8"
			aria-label="Main"
		>
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="text-xs font-medium whitespace-nowrap text-brand-navy transition-colors hover:text-brand-gold lg:text-sm xl:text-base"
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<!-- Right: phone CTA + hamburger -->
		<div class="flex items-center gap-2 sm:gap-3">
			<a
				href={phoneHref}
				aria-label={`Call ${phoneDisplay}`}
				class="inline-flex items-center gap-1.5 rounded-md bg-brand-gold px-2.5 py-2 text-xs font-bold whitespace-nowrap text-brand-navy transition-colors hover:bg-[#d1a63b] lg:px-4 lg:text-sm"
			>
				<svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path
						fill-rule="evenodd"
						clip-rule="evenodd"
						d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z"
					/>
				</svg>
				<span class="hidden sm:inline">{phoneDisplay}</span>
			</a>

			<!-- Hamburger toggle (mobile only) -->
			<button
				type="button"
				id="menu-toggle"
				class="group inline-flex items-center justify-center rounded-md p-2 text-brand-navy transition-colors hover:text-brand-gold md:hidden"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg
					class="size-6 group-aria-expanded:hidden"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
				</svg>
				<svg
					class="hidden size-6 group-aria-expanded:block"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</div>

		<!-- Mobile menu -->
		<nav
			id="mobile-menu"
			class="absolute inset-x-0 top-full hidden border-b border-gray-200 bg-white shadow-lg md:hidden"
			aria-label="Mobile"
		>
			<ul class="flex flex-col px-4 py-2 sm:px-6">
				{
					navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="block py-3 text-base font-medium text-brand-navy transition-colors hover:text-brand-gold"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");

	if (toggle && menu) {
		const setOpen = (open: boolean) => {
			menu.classList.toggle("hidden", !open);
			toggle.setAttribute("aria-expanded", String(open));
			toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
		};

		toggle.addEventListener("click", () => {
			setOpen(toggle.getAttribute("aria-expanded") !== "true");
		});

		menu.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", () => setOpen(false));
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") setOpen(false);
		});
	}
</script>
