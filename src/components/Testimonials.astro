---
import quoteIcon from "lucide-static/icons/quote.svg?raw";

const testimonials = [
	{
		name: "Tami",
		quote:
			"I had terrible injuries as a result of the accident I had and hiring Eric Blank to be on my side during this difficult process was the best thing I did.",
	},
	{
		name: "Joanna Crawford",
		quote:
			"I was very pleased with the recommendation, and I'm very happy with the service that I got here. I was very pleased with the process and the end result has been marvelous.",
	},
	{
		name: "Shaun Carradine",
		quote:
			"I appreciate you guys coming through, and showing me where to get things when I need to. Thanks for making my day.",
	},
	{
		name: "Warren Stewart",
		quote:
			"If you are looking for an attorney who will return your calls and e-mails and make you feel like you are being taken care of then look no further, Eric Blank is your guy.",
	},
];
---

<section class="bg-white" aria-labelledby="testimonials-heading">
	<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
				Client Testimonials
			</p>
			<h2
				id="testimonials-heading"
				class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
			>
				Real Clients. Real Words.
			</h2>
			<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
				These are the people we've fought for — and the results they describe.
			</p>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
			{
				testimonials.map((testimonial) => (
					<figure class="flex flex-col rounded-lg border border-gray-200 bg-white p-6 sm:p-8">
						<span
							aria-hidden="true"
							class="text-brand-navy/60 [&>svg]:size-8"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-4 text-base leading-relaxed text-pretty text-gray-700 sm:text-lg">
							{testimonial.quote}
						</blockquote>
						<figcaption class="mt-auto pt-6 text-base font-bold text-brand-navy">
							{testimonial.name}
						</figcaption>
					</figure>
				))
			}
		</div>

		<div class="mt-10 flex flex-col items-center justify-center gap-3 sm:mt-12 sm:flex-row sm:gap-4">
			<a
				href="https://ericblanklaw.com/testimonials"
				class="text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
			>
				See more client stories →
			</a>
			<span aria-hidden="true" class="hidden text-gray-300 sm:inline">|</span>
			<a
				href="https://ericblanklaw.com/video-testimonials"
				class="text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
			>
				Watch video testimonials →
			</a>
		</div>
	</div>
</section>
