---
const stats = [
	{ value: "Millions", label: "Recovered for Injury Victims" },
	{ value: "1,000+", label: "Cases Handled" },
	{ value: "22+", label: "Years of Experience" },
	{ value: "98%", label: "Client Satisfaction" },
];
---

<section class="bg-brand-navy text-white" aria-labelledby="results-heading">
	<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
				Proven Results
			</p>
			<h2
				id="results-heading"
				class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl"
			>
				Track Record That Speaks For Itself
			</h2>
			<div class="mx-auto mt-6 h-1 w-[60px] rounded-full bg-brand-gold"></div>
			<p class="mt-6 text-base text-pretty text-white/70 sm:text-lg">
				Decades of experience. Real outcomes for real people.
			</p>
		</div>

		<dl
			class="mx-auto mt-12 grid max-w-4xl grid-cols-2 gap-x-8 gap-y-10 lg:mt-16 lg:max-w-none lg:grid-cols-4"
		>
			{
				stats.map((stat) => (
					<div class="flex flex-col-reverse gap-2 text-center">
						<dt class="text-xs font-semibold tracking-wider text-white uppercase sm:text-sm">
							{stat.label}
						</dt>
						<dd class="text-4xl font-extrabold text-brand-gold sm:text-5xl lg:text-6xl">
							{stat.value}
						</dd>
					</div>
				))
			}
		</dl>

		<p class="mx-auto mt-12 max-w-2xl text-center text-sm text-pretty text-white/60">
			Past results do not guarantee similar outcomes in future cases. Every case is unique.
		</p>
	</div>
</section>
