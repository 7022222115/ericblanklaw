---
const values = [
	{
		title: "Better Compensation",
		description:
			"Going above and beyond a simple settlement to get you the maximum recovery the law allows.",
		iconPath:
			"M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
	},
	{
		title: "Better Health",
		description:
			"Getting you the best doctors available to guide your recovery — every step of the way.",
		iconPath:
			"M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z",
	},
	{
		title: "Better Communication",
		description:
			"Open, direct access to our team and your medical providers. No call centers. No runaround.",
		iconPath: "M7.9 20A9 9 0 1 0 4 16.1L2 22Z",
	},
	{
		title: "Better Representation",
		description:
			"A relentless fighter on your side against the insurance companies and their attorneys.",
		iconPath:
			"M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z",
	},
];
---

<section class="bg-white" aria-labelledby="values-heading">
	<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
				Why Choose Us
			</p>
			<h2
				id="values-heading"
				class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
			>
				The Better With Blank Difference
			</h2>
			<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
				Four standards we hold ourselves to — every client, every case.
			</p>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16 lg:grid-cols-4">
			{
				values.map((value) => (
					<article class="rounded-lg border border-gray-200 bg-white p-8 transition duration-200 hover:-translate-y-1 hover:border-brand-navy hover:shadow-lg">
						<svg
							class="size-12 text-brand-navy"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d={value.iconPath} />
						</svg>
						<h3 class="mt-5 text-xl font-bold text-brand-navy">{value.title}</h3>
						<p class="mt-2 leading-relaxed text-gray-600">{value.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
