---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import Badges from '../components/Badges.astro';
import Reviews from '../components/Reviews.astro';
import TestimonialGallery from '../components/TestimonialGallery.astro';
import Lightbox from '../components/Lightbox.astro';
import { googleAggregate } from '../data/reviews.js';
import starIcon from 'lucide-static/icons/star.svg?raw';
---

<html lang="en">
	<head>
		<BaseHead
			title="Client Reviews & Testimonials | Eric Blank Injury Attorneys Las Vegas"
			description="Real client reviews for Eric Blank Injury Attorneys — rated 4.8 stars across 452 Google reviews. Las Vegas personal injury law firm. Call (702) 222-2115."
			canonical="https://ericblanklaw.com/reviews"
		/>
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- A: page hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/reviews-hero.jpg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Client Reviews
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						What Our Clients Say
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						These are the people we've fought for, in their own words. For more reviews,
						see our Avvo profile or watch our video testimonials.
					</p>

					<div class="mt-6 flex flex-col items-center justify-center gap-2 sm:flex-row sm:gap-3">
						<div class="flex items-center gap-1" aria-hidden="true">
							{
								Array.from({ length: 5 }).map(() => (
									<span class="text-brand-gold [&>svg]:size-5 [&>svg]:fill-current" set:html={starIcon} />
								))
							}
						</div>
						<p class="text-base text-white">
							<span class="font-bold text-brand-gold">{googleAggregate.rating.toFixed(1)}</span>
							<span class="text-white/70"> / 5 · based on </span>
							<span class="font-semibold">{googleAggregate.count.toLocaleString()}</span>
							<span class="text-white/70"> Google reviews</span>
						</p>
					</div>
				</div>
			</section>

			<!-- B: client reviews (verbatim Google reviews component) -->
			<Reviews showHeader={false} />

			<!-- B1: video testimonial gallery -->
			<TestimonialGallery />

			<!-- B2: external review links -->
			<section class="bg-white">
				<div class="mx-auto max-w-[1200px] px-4 pb-16 sm:px-6 sm:pb-20 lg:px-8 lg:pb-28">
					<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="https://www.avvo.com/attorneys/89117-nv-eric-blank-4209956.html"
							target="_blank"
							rel="noopener"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-6 py-3.5 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto"
						>
							Read More Reviews on Avvo →
						</a>
						<a
							href="https://ericblanklaw.com/video-testimonials"
							class="inline-flex w-full items-center justify-center rounded-md border border-brand-navy/20 px-6 py-3.5 text-base font-bold text-brand-navy transition-colors hover:border-brand-navy sm:w-auto"
						>
							Watch Video Testimonials →
						</a>
					</div>
				</div>
			</section>

			<!-- C: recognition badges -->
			<Badges />

			<!-- D: contact form -->
			<Contact />
		</main>
		<Footer />

		<!-- Universal media lightbox (used by the video gallery) -->
		<Lightbox />
	</body>
</html>
