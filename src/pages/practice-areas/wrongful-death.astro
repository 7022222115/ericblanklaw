---
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';

import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import shieldIcon from 'lucide-static/icons/shield.svg?raw';
import phoneCallIcon from 'lucide-static/icons/phone-call.svg?raw';
import cameraIcon from 'lucide-static/icons/camera.svg?raw';
import stethoscopeIcon from 'lucide-static/icons/stethoscope.svg?raw';
import banIcon from 'lucide-static/icons/ban.svg?raw';
import scaleIcon from 'lucide-static/icons/scale.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import clipboardListIcon from 'lucide-static/icons/clipboard-list.svg?raw';
import handshakeIcon from 'lucide-static/icons/handshake.svg?raw';
import gavelIcon from 'lucide-static/icons/gavel.svg?raw';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import calendarClockIcon from 'lucide-static/icons/calendar-clock.svg?raw';
import shieldCheckIcon from 'lucide-static/icons/shield-check.svg?raw';
import quoteIcon from 'lucide-static/icons/quote.svg?raw';
import checkCircleIcon from 'lucide-static/icons/check-circle.svg?raw';
import circleDollarSignIcon from 'lucide-static/icons/circle-dollar-sign.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';

const title = "Las Vegas Wrongful Death Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"If you've lost a loved one because of someone else's negligence in Nevada, Eric Blank Injury Attorneys is here when you're ready. Compassionate counsel under NRS 41.085. No fees unless we recover for your family. Call (702) 222-2115.";

const heroTrust = ["26+ Years", "Compassionate Counsel", "Available 24/7", "No Fees Unless We Recover"];

const stats = [
	{ value: "Millions", label: "Recovered for Injury Victims" },
	{ value: "1000s", label: "of Injury Cases Handled" },
	{ value: "$0", label: "Out-of-Pocket Fees", note: "Contingency fee only" },
	{ value: "24/7", label: "When You're Ready To Talk" },
];

const steps = [
	{
		icon: shieldIcon,
		title: "Take Care Of Yourself And Your Family",
		text: "The legal claim can wait. Grief is the priority. We'll meet you where you are, on your timeline, when you're ready to talk.",
	},
	{
		icon: clipboardListIcon,
		title: "Preserve What Documentation You Can",
		text: "When you're able, hold on to police reports, hospital records, accident reports, autopsy and coroner records, and the contact information of any witnesses. We can help gather the rest.",
	},
	{
		icon: banIcon,
		title: "Don't Sign Anything",
		text: "If you're contacted by an insurance company, an employer, or anyone asking for a recorded statement, a release, or a medical authorization, please don't sign. Many of those documents primarily protect the other side.",
	},
	{
		icon: cameraIcon,
		title: "Keep A Record Of Expenses",
		text: "Save receipts and statements for medical bills incurred before the death, funeral and burial expenses, and any other costs that fell to the family. Nevada law lets the estate recover many of these.",
	},
	{
		icon: scaleIcon,
		title: "Don't Wait Too Long To Speak With An Attorney",
		text: "Nevada gives families a limited window — generally 2 years from the date of death — to bring a wrongful death claim. Evidence and witness memories can fade much faster than that.",
	},
	{
		icon: phoneCallIcon,
		title: "Reach Out When You're Ready",
		text: "There's no rush, no obligation, and no fee unless we recover for your family. When you're ready to talk, we're here.",
	},
];

const howWeHelp = [
	{
		icon: searchIcon,
		title: "Investigate The Cause",
		text: "We investigate exactly what happened — police reports, expert review, witness statements, photographs, surveillance — so the full picture of how and why your loved one died is on the record, and the right people are held accountable.",
	},
	{
		icon: clipboardListIcon,
		title: "Identify Every Source Of Recovery",
		text: "Wrongful death claims often involve more than one liable party — a driver and an employer, a property owner and a contractor, a manufacturer and a distributor. We pursue every applicable policy and every responsible party.",
	},
	{
		icon: handshakeIcon,
		title: "Walk With Your Family",
		text: "Wrongful death cases aren't only about money — they're about your family's voice in what happened. We keep you informed, walk through decisions together, and pursue a recovery that reflects your loved one's life.",
	},
	{
		icon: gavelIcon,
		title: "Try The Case If Needed",
		text: "When a defendant won't pay what's fair, we go to trial. Defendants and their insurers raise their numbers when they know we will.",
	},
];

const heirsRecover = [
	"Grief and sorrow",
	"Loss of probable financial support",
	"Loss of companionship, society, and comfort",
	"Loss of consortium",
	"The decedent's pain, suffering, or disfigurement before death",
];

const estateRecovers = [
	"Medical expenses incurred before death",
	"Funeral and burial expenses",
	"Other special damages incurred by the decedent before death",
	"Lost earnings the decedent would have made",
];

const nevadaLaws = [
	{
		icon: calendarClockIcon,
		title: "Statute of Limitations",
		text: "Nevada generally gives 2 years from the date of death to file a wrongful death claim (NRS 11.190). Some claims — for example, against government entities — have much shorter notice deadlines. We don't recommend letting the clock decide your family's case.",
	},
	{
		icon: scaleIcon,
		title: "Who Can File",
		text: "Under NRS 41.085, both the deceased's heirs and the personal representative of the estate may bring a wrongful death action. \"Heirs\" generally means the people who would inherit the decedent's separate property under Nevada intestate succession law — most often a spouse and children, and in some cases parents or other family members.",
	},
	{
		icon: shieldCheckIcon,
		title: "How Damages Are Split",
		text: "NRS 41.085 splits the recovery. Heirs are entitled to grief and sorrow, loss of probable support, companionship and consortium, and the decedent's pain and suffering before death. The estate may recover the decedent's pre-death medical expenses, funeral costs, and lost earnings. Personal representatives cannot recover pain-and-suffering damages — only the heirs can.",
	},
];

const faqs = [
	{
		q: "Who can bring a wrongful death claim in Nevada?",
		a: "Under NRS 41.085, two categories of plaintiffs may file: the decedent's heirs (people entitled to inherit the decedent's separate property under Nevada intestate succession law — often a spouse, children, and in some cases parents) and the personal representative of the estate. The two claims can be joined in a single action.",
	},
	{
		q: "How long do we have to file?",
		a: "Generally two years from the date of death, under NRS 11.190. Certain claims — for example, against a government entity — have much shorter notice deadlines, and other limited exceptions can apply. We recommend not waiting to at least talk with an attorney.",
	},
	{
		q: "What can our family actually recover?",
		a: "Nevada law splits the recovery. Heirs can recover for grief and sorrow, loss of companionship and consortium, loss of probable financial support, and damages for the decedent's pain and suffering before death. The estate can recover for the decedent's pre-death medical expenses, funeral and burial costs, and lost earnings.",
	},
	{
		q: "What if more than one person caused our loved one's death?",
		a: "Wrongful death cases often involve multiple defendants and insurers — for example, a driver and the driver's employer, or a property owner and a contractor. We identify every responsible party and every applicable insurance policy.",
	},
	{
		q: "Is a wrongful death claim the same as a criminal homicide case?",
		a: "No. A wrongful death claim is civil — it seeks money damages for the family's losses, and it can move forward independently of any criminal case. A civil judgment doesn't require a criminal conviction.",
	},
	{
		q: "How much does it cost to hire a wrongful death attorney?",
		a: "Our fee is contingency-based — there is no upfront cost and no hourly billing. We only get paid if we recover for your family, and the fee is a percentage of the recovery, agreed to in writing before we start.",
	},
];

const contactReasons = [
	{ text: "A confidential, no-obligation conversation", icon: checkCircleIcon },
	{ text: "No fees unless we recover for your family", icon: circleDollarSignIcon },
	{ text: "Available 24/7 — call when you're ready", icon: clockIcon },
];

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/practice-areas/wrongful-death#service",
			name: "Eric Blank Injury Attorneys — Wrongful Death Representation",
			serviceType: "Wrongful Death Legal Services",
			url: "https://ericblanklaw.com/practice-areas/wrongful-death",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			telephone: "+1-702-222-2115",
			priceRange: "Contingency Fee — No Fees Unless We Recover",
			areaServed: ["Las Vegas", "Henderson", "North Las Vegas", "Boulder City", "Clark County", "Nevada"],
			address: {
				"@type": "PostalAddress",
				streetAddress: "7860 W Sahara Ave Ste. 110",
				addressLocality: "Las Vegas",
				addressRegion: "NV",
				postalCode: "89117",
				addressCountry: "US",
			},
			employee: { "@id": "https://ericblanklaw.com/#attorney" },
		},
		{
			"@type": "Attorney",
			"@id": "https://ericblanklaw.com/#attorney",
			name: "Eric R. Blank",
			jobTitle: "Personal Injury Attorney",
		},
		{
			"@type": "FAQPage",
			"@id": "https://ericblanklaw.com/practice-areas/wrongful-death#faq",
			mainEntity: faqs.map((faq) => ({
				"@type": "Question",
				name: faq.q,
				acceptedAnswer: { "@type": "Answer", text: faq.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/practice-areas/wrongful-death"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- SECTION 1 — Hero -->
			<section class="bg-brand-navy text-white">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Wrongful Death In Nevada
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						Las Vegas Wrongful Death Attorney
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						Losing someone you love is devastating. When that loss comes from another
						person's negligence or wrongful act, grief layers with anger, questions, and
						unfamiliar legal decisions — most of them with deadlines. Nevada's wrongful
						death statute, NRS 41.085, gives certain family members and the estate the
						right to bring a claim. When you're ready to talk, Eric Blank Injury Attorneys
						is here. There's no rush, no obligation, and no fees unless we recover for
						your family.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="#contact"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Speak With Our Team
						</a>
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
						>
							<span class="[&>svg]:size-5" set:html={phoneIcon} aria-hidden="true" />
							(702) 222-2115
						</a>
					</div>
					<ul class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:text-sm">
						{
							heroTrust.map((item, index) => (
								<li
									class:list={[
										index > 0 &&
											"before:mx-2 before:text-brand-gold before:content-['•'] sm:before:mx-3",
									]}
								>
									{item}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SECTION 2 — Trust strip -->
			<section class="border-b border-gray-200 bg-white">
				<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
					<dl class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
						{
							stats.map((stat) => (
								<div class="text-center">
									<dd class="text-3xl font-extrabold text-brand-navy sm:text-4xl">
										{stat.value}
									</dd>
									<dt class="mt-1 text-sm font-semibold text-gray-600">{stat.label}</dt>
									{stat.note && <p class="mt-0.5 text-xs text-gray-500">{stat.note}</p>}
								</div>
							))
						}
					</dl>
				</div>
			</section>

			<!-- SECTION 3 — What to know -->
			<section class="bg-white" aria-labelledby="steps-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							In The Days Ahead
						</p>
						<h2
							id="steps-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What To Know After A Wrongful Death
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Grieving comes first. These are things to think about — gently — as you find
							your footing.
						</p>
					</div>
					<ol class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
						{
							steps.map((step, index) => (
								<li class="rounded-lg border border-gray-200 bg-white p-6">
									<div class="flex items-center gap-3">
										<span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-navy text-sm font-bold text-brand-gold">
											{index + 1}
										</span>
										<span
											class="text-brand-navy [&>svg]:size-7"
											set:html={step.icon}
											aria-hidden="true"
										/>
									</div>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{step.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{step.text}
									</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- SECTION 4 — How we help -->
			<section class="bg-gray-50" aria-labelledby="help-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Our Approach
						</p>
						<h2
							id="help-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							How Eric Blank Injury Attorneys Handles Wrongful Death Cases
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Eric Blank spent the early part of his career defending insurance companies.
							We bring that insider knowledge to every wrongful death case — the same
							experience we apply across our{" "}
							<a
								href="/practice-areas"
								class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
							>
								personal injury practice
							</a>.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-4">
						{
							howWeHelp.map((item) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={item.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{item.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 5 — Damages (NRS 41.085 split) -->
			<section class="bg-white" aria-labelledby="damages-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							What Nevada Law Allows
						</p>
						<h2
							id="damages-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What A Nevada Wrongful Death Claim Can Recover
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Nevada's wrongful death statute (NRS 41.085) allows two distinct sets of
							recoveries — one for the deceased's heirs, one for the estate.
						</p>
					</div>
					<div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Heirs May Recover</h3>
							<ul class="mt-5 space-y-3">
								{
									heirsRecover.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">The Estate May Recover</h3>
							<ul class="mt-5 space-y-3">
								{
									estateRecovers.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						Under NRS 41.085, wrongful death recoveries paid to heirs are generally not
						available to satisfy the decedent's debts. The amount available in any
						individual case depends on the facts, the at-fault parties, and the insurance
						and assets behind them — a{" "}
						<a
							href="/contact"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
						>
							free consultation
						</a>{" "}
						is the best way to get a real answer.
					</p>
				</div>
			</section>

			<!-- SECTION 6 — Nevada law -->
			<section class="bg-gray-50" aria-labelledby="law-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Nevada Law
						</p>
						<h2
							id="law-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Key Nevada Wrongful Death Rules
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3 lg:mt-16">
						{
							nevadaLaws.map((law) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={law.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{law.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{law.text}
									</p>
								</div>
							))
						}
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						This is general information, not legal advice for your family's specific
						situation. Talk to an attorney about the facts.
					</p>
				</div>
			</section>

			<!-- SECTION 7 — FAQ -->
			<section class="bg-white" aria-labelledby="faq-heading">
				<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
					<div class="text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							FAQ
						</p>
						<h2
							id="faq-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Common Wrongful Death Questions
						</h2>
					</div>
					<div class="mt-10 space-y-8 lg:mt-12">
						{
							faqs.map((faq) => (
								<div>
									<h3 class="text-lg font-bold text-brand-navy sm:text-xl">{faq.q}</h3>
									<p class="mt-2 text-base leading-relaxed text-pretty text-gray-600">
										{faq.a}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 8 — Featured testimonial -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<figure>
						<span
							aria-hidden="true"
							class="mx-auto block w-fit text-brand-navy/60 [&>svg]:size-10"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-5 text-xl font-medium text-balance text-brand-navy sm:text-2xl">
							I had terrible injuries as a result of the accident I had and hiring Eric
							Blank to be on my side during this difficult process was the best thing I did.
						</blockquote>
						<figcaption class="mt-5 text-base font-bold text-brand-navy">— Tami</figcaption>
					</figure>
					<a
						href="/reviews"
						class="mt-8 inline-block text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
					>
						Read more client reviews →
					</a>
				</div>
			</section>

			<!-- SECTION 9 — Final CTA + contact form -->
			<section
				id="contact"
				class="scroll-mt-24 bg-brand-navy text-white"
				aria-labelledby="cta-heading"
			>
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<h2
							id="cta-heading"
							class="text-3xl font-bold tracking-tight text-balance sm:text-4xl"
						>
							When You're Ready To Talk, We're Here
						</h2>
						<p class="mt-3 text-base text-pretty text-white/70 sm:text-lg">
							Confidential, no obligation, and no fees unless we recover for your family.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
								What To Expect
							</p>
							<h3 class="mt-3 text-xl font-bold sm:text-2xl">
								A Conversation, Not A Sales Pitch
							</h3>
							<ul class="mt-6 space-y-4">
								{
									contactReasons.map((reason) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={reason.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-white/90 sm:text-lg">{reason.text}</span>
										</li>
									))
								}
							</ul>
							<p class="mt-6 max-w-md text-base text-pretty text-white/70">
								Nevada gives families a limited window — generally 2 years from the date
								of death — to bring a wrongful death claim. But the path forward starts
								with a conversation. When you're ready, we're here.
							</p>
						</div>
						<ContactForm />
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
