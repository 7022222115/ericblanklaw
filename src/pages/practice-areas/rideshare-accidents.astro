---
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import TestimonialCarousel from '../../components/TestimonialCarousel.astro';
import Lightbox from '../../components/Lightbox.astro';

import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import shieldIcon from 'lucide-static/icons/shield.svg?raw';
import phoneCallIcon from 'lucide-static/icons/phone-call.svg?raw';
import cameraIcon from 'lucide-static/icons/camera.svg?raw';
import stethoscopeIcon from 'lucide-static/icons/stethoscope.svg?raw';
import banIcon from 'lucide-static/icons/ban.svg?raw';
import scaleIcon from 'lucide-static/icons/scale.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import clipboardListIcon from 'lucide-static/icons/clipboard-list.svg?raw';
import handshakeIcon from 'lucide-static/icons/handshake.svg?raw';
import gavelIcon from 'lucide-static/icons/gavel.svg?raw';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import calendarClockIcon from 'lucide-static/icons/calendar-clock.svg?raw';
import shieldCheckIcon from 'lucide-static/icons/shield-check.svg?raw';
import quoteIcon from 'lucide-static/icons/quote.svg?raw';
import checkCircleIcon from 'lucide-static/icons/check-circle.svg?raw';
import circleDollarSignIcon from 'lucide-static/icons/circle-dollar-sign.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';

const title = "Las Vegas Uber & Lyft Accident Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"Hurt in a Las Vegas Uber or Lyft crash? The insurance tier depends on the driver's app status. Eric Blank Injury Attorneys untangles multi-policy rideshare cases. Free consultation. No fees unless we win. Call (702) 222-2115.";

const heroTrust = ["26+ Years", "Millions Recovered", "Available 24/7", "Free Consultation"];

const stats = [
	{ value: "Millions", label: "Recovered for Rideshare Victims" },
	{ value: "1000s", label: "of Uber & Lyft Cases Handled" },
	{ value: "$0", label: "Out-of-Pocket Fees", note: "Contingency fee only" },
	{ value: "24/7", label: "Free Consultation" },
];

const steps = [
	{
		icon: shieldIcon,
		title: "Get To Safety",
		text: "If you can move, get yourself and any other occupants out of traffic. Then check yourself for injuries before doing anything else.",
	},
	{
		icon: phoneCallIcon,
		title: "Call 911",
		text: "Always get a police report — even if the rideshare driver doesn't want to. On Vegas surface streets that's Metro; on I-15 and the highways it's Nevada Highway Patrol. Don't leave it to the rideshare driver to make the call.",
	},
	{
		icon: cameraIcon,
		title: "Document Everything",
		text: "Photograph the vehicles, the road, and your injuries. Get the driver's name, license, plate, and personal insurance — AND screenshots of the Uber or Lyft trip in the app, showing the driver's name, the ride status, and the time. App data is central evidence in these cases.",
	},
	{
		icon: stethoscopeIcon,
		title: "See A Doctor",
		text: "Get evaluated even if you feel fine. Adrenaline hides soft-tissue, head, and internal injuries that surface days later. Gaps in treatment are the first thing insurers use to discount your claim.",
	},
	{
		icon: banIcon,
		title: "Don't Talk To Any Insurer",
		text: "In a rideshare case, multiple insurers may call — the driver's personal carrier, the rideshare company's insurer, and the other driver's insurer. None of them are on your side. Refer all of them to your lawyer.",
	},
	{
		icon: scaleIcon,
		title: "Call An Attorney First",
		text: "Rideshare cases hinge on app-status data, which the rideshare company controls. The faster a lawyer issues a preservation letter, the more of that evidence survives — and the clearer it becomes which policy pays.",
	},
];

const howWeHelp = [
	{
		icon: searchIcon,
		title: "Investigate The Crash & App Status",
		text: "We move fast to lock in which insurance tier applies — driver's personal coverage, rideshare contingent coverage, or the company's full liability policy. App-status data and trip records live with the rideshare company, and we move quickly to preserve them.",
	},
	{
		icon: clipboardListIcon,
		title: "Build The Medical Record",
		text: "We work with your doctors to document every injury, current and future, so the full cost of the crash is on paper — not guessed at by an adjuster.",
	},
	{
		icon: handshakeIcon,
		title: "Negotiate With Multiple Insurers",
		text: "Rideshare cases routinely involve three or four carriers. Eric Blank's insurance-defense experience tells us how each one values its exposure and where each one cuts — and we use that to push for a real number.",
	},
	{
		icon: gavelIcon,
		title: "Try The Case If Needed",
		text: "Insurance companies settle harder when they know your attorney is willing to put the case in front of a jury. We prepare every rideshare case as if it's going to trial.",
	},
];

const economicDamages = [
	"Medical bills — past and future treatment",
	"Lost wages and reduced future earning capacity",
	"Property damage to your vehicle or belongings",
	"Out-of-pocket costs — transportation, prescriptions, and more",
];

const nonEconomicDamages = [
	"Pain and suffering",
	"Emotional distress",
	"Loss of enjoyment of life",
	"Permanent disability or disfigurement",
	"Loss of consortium",
];

const nevadaLaws = [
	{
		icon: calendarClockIcon,
		title: "Statute of Limitations",
		text: "Nevada gives you 2 years from the date of the crash to file a rideshare-related personal injury lawsuit (NRS 11.190). Miss that deadline and your claim is gone — and rideshare app data is best preserved much earlier than that.",
	},
	{
		icon: scaleIcon,
		title: "Comparative Negligence",
		text: "Nevada follows a modified comparative negligence rule. If you are 51% or more at fault you recover nothing; if you are partly at fault but under that, your recovery is reduced by your share.",
	},
	{
		icon: shieldCheckIcon,
		title: "Rideshare Insurance Tiers",
		text: "Which insurance policy applies depends on the rideshare driver's app status at the time of the crash. App off: only the driver's personal auto insurance. App on but waiting for a request: limited contingent liability coverage — commonly stated as $50,000 per person, $100,000 per accident, and $25,000 property damage. Ride accepted through drop-off: a $1,000,000 liability policy is generally available, along with uninsured/underinsured motorist coverage. (Nevada law currently sets the rideshare company's per-incident liability at $1,000,000.)",
	},
];

const faqs = [
	{
		q: "Who pays if my Uber driver caused the crash?",
		a: "It depends on the driver's app status at the moment of the crash. If a trip was active — you were in the car or the driver was on the way to pick you up — Uber's commercial liability policy of up to $1 million is generally available, along with uninsured/underinsured motorist coverage. If the driver was logged in but waiting for a request, Uber provides limited contingent liability coverage. If the app was off, only the driver's personal insurance is in play. The same general structure applies to Lyft.",
	},
	{
		q: "What if I was a passenger and the OTHER driver caused the crash?",
		a: "You can usually pursue the other driver's insurance, and — if their coverage is inadequate — uninsured/underinsured motorist coverage under the rideshare company's policy, which is generally in effect while you're on an active trip. We chase down every available source of coverage.",
	},
	{
		q: "What if I was hit by an Uber or Lyft driver while I was walking, biking, or in my own car?",
		a: "The same framework applies — the driver's app status determines which policy pays. When the rideshare driver was on an active trip or logged in waiting for a request, the rideshare company's coverage is involved. When the app was off, you're pursuing the driver's personal auto policy.",
	},
	{
		q: "How long do I have to file a rideshare accident claim in Nevada?",
		a: "Two years from the date of the crash, under NRS 11.190. Don't wait — rideshare app data and trip records are best preserved early in the case, and witness memories fade fast.",
	},
	{
		q: "Will my own auto insurance get involved?",
		a: "It can — especially your uninsured/underinsured motorist coverage if the at-fault driver's coverage falls short. Eric Blank's insurance-defense experience helps us sort through every potentially available policy and identify where stacking coverage makes sense.",
	},
	{
		q: "How much does it cost to hire a rideshare accident lawyer?",
		a: "Our fee is contingency-based — no upfront cost and no hourly billing. We only get paid if we win, and the fee is a percentage of your recovery, agreed to in writing before we start.",
	},
];

const contactReasons = [
	{ text: "Free, no-obligation case review", icon: checkCircleIcon },
	{ text: "No fees unless we win your case", icon: circleDollarSignIcon },
	{ text: "Available 24/7 — nights, weekends, holidays", icon: clockIcon },
];

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/practice-areas/rideshare-accidents#service",
			name: "Eric Blank Injury Attorneys — Uber & Lyft Accident Representation",
			serviceType: "Rideshare Accident Legal Services",
			url: "https://ericblanklaw.com/practice-areas/rideshare-accidents",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			telephone: "+1-702-222-2115",
			priceRange: "Contingency Fee — No Fees Unless We Win",
			areaServed: ["Las Vegas", "Henderson", "North Las Vegas", "Boulder City", "Clark County", "Nevada"],
			address: {
				"@type": "PostalAddress",
				streetAddress: "7860 W Sahara Ave Ste. 110",
				addressLocality: "Las Vegas",
				addressRegion: "NV",
				postalCode: "89117",
				addressCountry: "US",
			},
			employee: { "@id": "https://ericblanklaw.com/#attorney" },
		},
		{
			"@type": "Attorney",
			"@id": "https://ericblanklaw.com/#attorney",
			name: "Eric R. Blank",
			jobTitle: "Personal Injury Attorney",
		},
		{
			"@type": "FAQPage",
			"@id": "https://ericblanklaw.com/practice-areas/rideshare-accidents#faq",
			mainEntity: faqs.map((faq) => ({
				"@type": "Question",
				name: faq.q,
				acceptedAnswer: { "@type": "Answer", text: faq.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/practice-areas/rideshare-accidents"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- SECTION 1 — Hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/rideshare-accidents-hero.jpeg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Las Vegas Rideshare Accidents
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						Las Vegas Uber & Lyft Accident Attorney
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						Uber and Lyft crashes turn on one question every other auto case ignores: at
						the moment of the crash, was the driver app-off, logged in but waiting for a
						ride, or on an active trip? The answer determines which insurance policy
						pays — and the gap between them can be enormous. For over 26 years, Eric Blank
						Injury Attorneys has untangled multi-policy auto cases. Free consultation, and
						no fees unless we win.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="#contact"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Free Case Review
						</a>
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
						>
							<span class="[&>svg]:size-5" set:html={phoneIcon} aria-hidden="true" />
							(702) 222-2115
						</a>
					</div>
					<ul class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:text-sm">
						{
							heroTrust.map((item, index) => (
								<li
									class:list={[
										index > 0 &&
											"before:mx-2 before:text-brand-gold before:content-['•'] sm:before:mx-3",
									]}
								>
									{item}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SECTION 2 — Trust strip -->
			<section class="border-b border-gray-200 bg-white">
				<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
					<dl class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
						{
							stats.map((stat) => (
								<div class="text-center">
									<dd class="text-3xl font-extrabold text-brand-navy sm:text-4xl">
										{stat.value}
									</dd>
									<dt class="mt-1 text-sm font-semibold text-gray-600">{stat.label}</dt>
									{stat.note && <p class="mt-0.5 text-xs text-gray-500">{stat.note}</p>}
								</div>
							))
						}
					</dl>
				</div>
			</section>

			<!-- SECTION 3 — What to do after a crash -->
			<section class="bg-white" aria-labelledby="steps-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							First Steps
						</p>
						<h2
							id="steps-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What To Do After An Uber Or Lyft Crash In Las Vegas
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							The first hours after the crash shape your entire claim — and rideshare
							evidence vanishes fastest of all.
						</p>
					</div>
					<ol class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
						{
							steps.map((step, index) => (
								<li class="rounded-lg border border-gray-200 bg-white p-6">
									<div class="flex items-center gap-3">
										<span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-navy text-sm font-bold text-brand-gold">
											{index + 1}
										</span>
										<span
											class="text-brand-navy [&>svg]:size-7"
											set:html={step.icon}
											aria-hidden="true"
										/>
									</div>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{step.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{step.text}
									</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- SECTION 4 — How we help -->
			<section class="bg-gray-50" aria-labelledby="help-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Our Approach
						</p>
						<h2
							id="help-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							How Eric Blank Injury Attorneys Handles Rideshare Cases
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Eric Blank spent the early part of his career defending insurance companies.
							We bring that insider knowledge to every rideshare case — the same edge we
							apply across our{" "}
							<a
								href="/practice-areas"
								class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
							>
								personal injury practice
							</a>.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-4">
						{
							howWeHelp.map((item) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={item.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{item.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 5 — What you can recover -->
			<section class="bg-white" aria-labelledby="damages-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Damages
						</p>
						<h2
							id="damages-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What Rideshare Crash Victims Can Recover In Nevada
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Nevada law lets injury victims recover compensatory damages — both the
							concrete financial losses and the human cost of the crash. In rare cases
							involving especially reckless conduct, punitive damages may also apply.
						</p>
					</div>
					<div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									economicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Non-Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									nonEconomicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						Nevada caps damages in medical malpractice cases but <strong>not</strong> in
						general personal injury claims. The amount you can recover depends on the
						specifics of your case — a{" "}
						<a
							href="/contact"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
						>
							free consultation
						</a>{" "}
						is the best way to get a real answer.
					</p>
				</div>
			</section>

			<!-- SECTION 6 — Nevada law -->
			<section class="bg-gray-50" aria-labelledby="law-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Nevada Law
						</p>
						<h2
							id="law-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Key Nevada Rideshare Accident Laws
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3 lg:mt-16">
						{
							nevadaLaws.map((law) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={law.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{law.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{law.text}
									</p>
								</div>
							))
						}
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						This is general information, not legal advice for your specific case. Talk to an
						attorney about the facts of your accident.
					</p>
				</div>
			</section>

			<!-- SECTION 7 — FAQ -->
			<section class="bg-white" aria-labelledby="faq-heading">
				<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
					<div class="text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							FAQ
						</p>
						<h2
							id="faq-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Common Rideshare Accident Questions
						</h2>
					</div>
					<div class="mt-10 space-y-8 lg:mt-12">
						{
							faqs.map((faq) => (
								<div>
									<h3 class="text-lg font-bold text-brand-navy sm:text-xl">{faq.q}</h3>
									<p class="mt-2 text-base leading-relaxed text-pretty text-gray-600">
										{faq.a}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 8 — Featured testimonial -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<figure>
						<span
							aria-hidden="true"
							class="mx-auto block w-fit text-brand-navy/60 [&>svg]:size-10"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-5 text-xl font-medium text-balance text-brand-navy sm:text-2xl">
							I had terrible injuries as a result of the accident I had and hiring Eric
							Blank to be on my side during this difficult process was the best thing I did.
						</blockquote>
						<figcaption class="mt-5 text-base font-bold text-brand-navy">— Tami</figcaption>
					</figure>
					<a
						href="/reviews"
						class="mt-8 inline-block text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
					>
						Read more client reviews →
					</a>
				</div>
			</section>

			<!-- Video testimonial carousel -->
			<TestimonialCarousel />

			<!-- SECTION 9 — Final CTA + contact form -->
			<section
				id="contact"
				class="scroll-mt-24 bg-brand-navy text-white"
				aria-labelledby="cta-heading"
			>
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<h2
							id="cta-heading"
							class="text-3xl font-bold tracking-tight text-balance sm:text-4xl"
						>
							Request Your Free Case Review
						</h2>
						<p class="mt-3 text-base text-pretty text-white/70 sm:text-lg">
							It's free, confidential, and there's no obligation.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
								Why Call Now
							</p>
							<h3 class="mt-3 text-xl font-bold sm:text-2xl">
								Three Reasons To Reach Out Today
							</h3>
							<ul class="mt-6 space-y-4">
								{
									contactReasons.map((reason) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={reason.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-white/90 sm:text-lg">{reason.text}</span>
										</li>
									))
								}
							</ul>
							<p class="mt-6 max-w-md text-base text-pretty text-white/70">
								Rideshare cases turn on app-status data held by Uber and Lyft — and best
								preserved with an early lawyer's letter. The sooner we hear from you, the
								more we can do.
							</p>
						</div>
						<ContactForm />
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<!-- Universal media lightbox (used by the carousel) -->
		<Lightbox />
	</body>
</html>
