---
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import TestimonialCarousel from '../../components/TestimonialCarousel.astro';
import Lightbox from '../../components/Lightbox.astro';
import { firmNode, attorneyNode } from '../../data/firm';

import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import shieldIcon from 'lucide-static/icons/shield.svg?raw';
import phoneCallIcon from 'lucide-static/icons/phone-call.svg?raw';
import cameraIcon from 'lucide-static/icons/camera.svg?raw';
import stethoscopeIcon from 'lucide-static/icons/stethoscope.svg?raw';
import banIcon from 'lucide-static/icons/ban.svg?raw';
import scaleIcon from 'lucide-static/icons/scale.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import clipboardListIcon from 'lucide-static/icons/clipboard-list.svg?raw';
import handshakeIcon from 'lucide-static/icons/handshake.svg?raw';
import gavelIcon from 'lucide-static/icons/gavel.svg?raw';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import calendarClockIcon from 'lucide-static/icons/calendar-clock.svg?raw';
import shieldCheckIcon from 'lucide-static/icons/shield-check.svg?raw';
import quoteIcon from 'lucide-static/icons/quote.svg?raw';
import checkCircleIcon from 'lucide-static/icons/check-circle.svg?raw';
import circleDollarSignIcon from 'lucide-static/icons/circle-dollar-sign.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';
import fileTextIcon from 'lucide-static/icons/file-text.svg?raw';
import landmarkIcon from 'lucide-static/icons/landmark.svg?raw';

const title = "Las Vegas School Bullying & Student Safety Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"When a Nevada school fails to keep a child safe from bullying, families have options. Eric Blank Injury Attorneys offers a free, confidential conversation about your situation. Call (702) 222-2115.";

const heroTrust = ["26+ Years", "Millions Recovered", "Available 24/7", "Free Consultation"];

const stats = [
	{ value: "Millions", label: "Recovered for Crash Victims" },
	{ value: "1000s", label: "of Injury Cases Handled" },
	{ value: "$0", label: "Out-of-Pocket Fees", note: "Contingency fee only" },
	{ value: "24/7", label: "Free Consultation" },
];

const steps = [
	{
		icon: shieldIcon,
		title: "Make Sure Your Child Is Safe First",
		text: "Before anything legal, focus on your child's immediate safety and wellbeing. Medical care and emotional support come first.",
	},
	{
		icon: clipboardListIcon,
		title: "Document Everything",
		text: "Save messages, photos, screenshots, medical and counseling records, and the dates of any incidents. Write down who you told at the school and when.",
	},
	{
		icon: fileTextIcon,
		title: "Report It In Writing",
		text: "Nevada schools have a duty to investigate reported bullying. Reporting in writing — and keeping a copy — creates a record that the school was on notice.",
	},
	{
		icon: scaleIcon,
		title: "Talk To Someone Who Can Explain Your Options",
		text: "Cases involving schools have specific rules and deadlines, especially when a public school district is involved. A conversation early on helps you understand where you stand.",
	},
];

const howWeHelp = [
	{
		icon: handshakeIcon,
		title: "Listen First",
		text: "Every family's situation is different. We start by understanding what happened to your child and what you need.",
	},
	{
		icon: searchIcon,
		title: "Investigate What The School Knew",
		text: "We look at whether the school was notified, whether it followed its own policies, and whether it met its legal duty to act.",
	},
	{
		icon: clipboardListIcon,
		title: "Explain Your Realistic Options",
		text: "We're honest about what a claim against a school or district involves — including the limits — so you can make an informed decision.",
	},
	{
		icon: shieldIcon,
		title: "Stand With Your Family",
		text: "If we move forward together, we handle the legal side so you can focus on your child.",
	},
];

const economicDamages = [
	"Medical and counseling costs",
	"Therapy and treatment expenses",
	"Costs of changing schools or programs",
	"Related out-of-pocket expenses",
];

const nonEconomicDamages = [
	"Physical pain",
	"Emotional and psychological harm",
	"Loss of enjoyment of school and childhood activities",
];

const nevadaLaws = [
	{
		icon: shieldCheckIcon,
		title: "Schools Have A Legal Duty To Act",
		text: "Nevada law (NRS 388.121 through 388.1395) prohibits bullying and cyber-bullying in public schools and requires staff to report and investigate it. When a school is told about bullying and does nothing, it may have failed a duty the law places on it.",
	},
	{
		icon: scaleIcon,
		title: "Parents Have A Right To Push For Action",
		text: "Nevada law specifically recognizes a parent's or guardian's authority to petition a court to compel a school to perform its safe-environment duty — and states that this remedy is not the only one available.",
	},
	{
		icon: landmarkIcon,
		title: "Claims Against Public Schools Have Special Rules",
		text: "A Nevada public school district is a government entity. That brings specific notice requirements and a cap on the damages recoverable from a government body (currently $200,000 per claimant, under NRS 41.035). These rules make early legal guidance especially important.",
	},
	{
		icon: calendarClockIcon,
		title: "Deadlines Apply — And They Can Be Short",
		text: "Nevada's general personal-injury deadline is two years (NRS 11.190), but claims involving a government entity can carry their own earlier notice steps. Because a child is involved, some timelines may work differently. The safest step is to ask early.",
	},
];

const faqs = [
	{
		q: "Can I sue a school for bullying in Nevada?",
		a: "Sometimes. Nevada schools have a legal duty to provide a safe environment and to respond to reported bullying. Whether a claim is possible depends on what the school knew, what it did, and the harm your child suffered. The honest answer is that it's fact-specific — which is why a conversation helps.",
	},
	{
		q: "What if the school is a public school?",
		a: "Public school districts are government entities, which adds special rules: notice requirements and a limit on the damages that can be recovered. It doesn't mean you have no options — it means the path is specific, and getting guidance early matters.",
	},
	{
		q: "What should I do right now?",
		a: "Make sure your child is safe and supported, document what's happened, and report the bullying to the school in writing. Keep copies of everything.",
	},
	{
		q: "Does my child have to testify or relive it?",
		a: "We handle these cases with care for the child involved. There are ways to move a case forward while protecting your child's wellbeing, and we'll talk through them honestly with you.",
	},
	{
		q: "What does it cost to talk to you?",
		a: "Nothing. The consultation is free and confidential, and if we work together, there are no fees unless we recover for you.",
	},
	{
		q: "Is it too late if this happened a while ago?",
		a: "Maybe not, but deadlines apply and some can be short — especially when a public school is involved. The sooner you ask, the more options you're likely to have.",
	},
];

const contactReasons = [
	{ text: "A free, confidential conversation", icon: checkCircleIcon },
	{ text: "No fees unless we recover for you", icon: circleDollarSignIcon },
	{ text: "We move at a pace that's right for your family", icon: clockIcon },
];

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		firmNode,
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/practice-areas/school-bullying#service",
			name: "Eric Blank Injury Attorneys — School Bullying & Student Safety Representation",
			serviceType: "School Bullying & Student Safety Legal Services",
			url: "https://ericblanklaw.com/practice-areas/school-bullying",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			priceRange: "Contingency Fee — No Fees Unless We Win",
			provider: { "@id": "https://ericblanklaw.com/#legalservice" },
			employee: { "@id": "https://ericblanklaw.com/#attorney" },
		},
		attorneyNode,
		{
			"@type": "FAQPage",
			"@id": "https://ericblanklaw.com/practice-areas/school-bullying#faq",
			mainEntity: faqs.map((faq) => ({
				"@type": "Question",
				name: faq.q,
				acceptedAnswer: { "@type": "Answer", text: faq.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/practice-areas/school-bullying"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- SECTION 1 — Hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/school-bullying-hero.jpeg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						School Bullying & Student Safety
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						When A School Fails To Keep A Child Safe
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						Nevada law requires schools to provide a safe learning environment and to act
						when bullying is reported. When a school ignores the warning signs and a child
						is harmed, families have options. We're here to talk through them with you.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="#contact"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Talk With Our Team
						</a>
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
						>
							<span class="[&>svg]:size-5" set:html={phoneIcon} aria-hidden="true" />
							(702) 222-2115
						</a>
					</div>
					<ul class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:text-sm">
						{
							heroTrust.map((item, index) => (
								<li
									class:list={[
										index > 0 &&
											"before:mx-2 before:text-brand-gold before:content-['•'] sm:before:mx-3",
									]}
								>
									{item}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SECTION 2 — Trust strip -->
			<section class="border-b border-gray-200 bg-white">
				<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
					<dl class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
						{
							stats.map((stat) => (
								<div class="text-center">
									<dd class="text-3xl font-extrabold text-brand-navy sm:text-4xl">
										{stat.value}
									</dd>
									<dt class="mt-1 text-sm font-semibold text-gray-600">{stat.label}</dt>
									{stat.note && <p class="mt-0.5 text-xs text-gray-500">{stat.note}</p>}
								</div>
							))
						}
					</dl>
				</div>
			</section>

			<!-- SECTION 3 — First steps -->
			<section class="bg-white" aria-labelledby="steps-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							First Steps
						</p>
						<h2
							id="steps-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							If Your Child Is Being Bullied, Here's Where To Start
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							These first steps protect your child and preserve what matters if you decide
							to look into your options.
						</p>
					</div>
					<ol class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
						{
							steps.map((step, index) => (
								<li class="rounded-lg border border-gray-200 bg-white p-6">
									<div class="flex items-center gap-3">
										<span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-navy text-sm font-bold text-brand-gold">
											{index + 1}
										</span>
										<span
											class="text-brand-navy [&>svg]:size-7"
											set:html={step.icon}
											aria-hidden="true"
										/>
									</div>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{step.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{step.text}
									</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- SECTION 4 — How we help -->
			<section class="bg-gray-50" aria-labelledby="help-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Our Approach
						</p>
						<h2
							id="help-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							How Eric Blank Injury Attorneys Can Help
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							We approach these cases with care for the family and the child at the center
							of them — part of how we handle our broader{" "}
							<a
								href="/practice-areas"
								class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
							>
								personal injury practice
							</a>.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-4">
						{
							howWeHelp.map((item) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={item.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{item.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 5 — What you can recover -->
			<section class="bg-white" aria-labelledby="damages-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Damages
						</p>
						<h2
							id="damages-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What Families May Be Able To Recover
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							When a school's failure to act harms a child, Nevada law may allow a family to
							recover both the concrete financial costs and the human toll of what the child
							has been through.
						</p>
					</div>
					<div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									economicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Non-Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									nonEconomicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						Every family's situation is different, and what a claim may involve depends on
						the specific facts. A{" "}
						<a
							href="/contact"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
						>
							free, confidential conversation
						</a>{" "}
						is the best way to understand your options.
					</p>
				</div>
			</section>

			<!-- SECTION 6 — Nevada law -->
			<section class="bg-gray-50" aria-labelledby="law-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Nevada Law
						</p>
						<h2
							id="law-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Key Nevada Student-Safety Laws
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4 lg:mt-16">
						{
							nevadaLaws.map((law) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={law.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{law.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{law.text}
									</p>
								</div>
							))
						}
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						This is general information, not legal advice for your specific case. Talk to an
						attorney about the facts of your situation.
					</p>
				</div>
			</section>

			<!-- SECTION 7 — FAQ -->
			<section class="bg-white" aria-labelledby="faq-heading">
				<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
					<div class="text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							FAQ
						</p>
						<h2
							id="faq-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Common Questions From Families
						</h2>
					</div>
					<div class="mt-10 space-y-8 lg:mt-12">
						{
							faqs.map((faq) => (
								<div>
									<h3 class="text-lg font-bold text-brand-navy sm:text-xl">{faq.q}</h3>
									<p class="mt-2 text-base leading-relaxed text-pretty text-gray-600">
										{faq.a}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 8 — Featured testimonial -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<figure>
						<span
							aria-hidden="true"
							class="mx-auto block w-fit text-brand-navy/60 [&>svg]:size-10"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-5 text-xl font-medium text-balance text-brand-navy sm:text-2xl">
							I had terrible injuries as a result of the accident I had and hiring Eric
							Blank to be on my side during this difficult process was the best thing I did.
						</blockquote>
						<figcaption class="mt-5 text-base font-bold text-brand-navy">— Tami</figcaption>
					</figure>
					<a
						href="/reviews"
						class="mt-8 inline-block text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
					>
						Read more client reviews →
					</a>
				</div>
			</section>

			<!-- Video testimonial carousel -->
			<TestimonialCarousel />

			<!-- SECTION 9 — Final CTA + contact form -->
			<section
				id="contact"
				class="scroll-mt-24 bg-brand-navy text-white"
				aria-labelledby="cta-heading"
			>
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<h2
							id="cta-heading"
							class="text-3xl font-bold tracking-tight text-balance sm:text-4xl"
						>
							If Your Child Was Hurt And The School Should Have Acted
						</h2>
						<p class="mt-3 text-base text-pretty text-white/70 sm:text-lg">
							You don't have to figure this out alone. Talk with our team — free,
							confidential, and at your pace.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
								What To Expect
							</p>
							<h3 class="mt-3 text-xl font-bold sm:text-2xl">
								A Conversation, Not A Commitment
							</h3>
							<ul class="mt-6 space-y-4">
								{
									contactReasons.map((reason) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={reason.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-white/90 sm:text-lg">{reason.text}</span>
										</li>
									))
								}
							</ul>
							<p class="mt-6 max-w-md text-base text-pretty text-white/70">
								Cases involving schools have specific rules and deadlines, and your child's
