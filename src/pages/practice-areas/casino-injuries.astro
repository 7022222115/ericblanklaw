---
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';

import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import shieldIcon from 'lucide-static/icons/shield.svg?raw';
import phoneCallIcon from 'lucide-static/icons/phone-call.svg?raw';
import cameraIcon from 'lucide-static/icons/camera.svg?raw';
import stethoscopeIcon from 'lucide-static/icons/stethoscope.svg?raw';
import banIcon from 'lucide-static/icons/ban.svg?raw';
import scaleIcon from 'lucide-static/icons/scale.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import clipboardListIcon from 'lucide-static/icons/clipboard-list.svg?raw';
import handshakeIcon from 'lucide-static/icons/handshake.svg?raw';
import gavelIcon from 'lucide-static/icons/gavel.svg?raw';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import calendarClockIcon from 'lucide-static/icons/calendar-clock.svg?raw';
import shieldCheckIcon from 'lucide-static/icons/shield-check.svg?raw';
import quoteIcon from 'lucide-static/icons/quote.svg?raw';
import checkCircleIcon from 'lucide-static/icons/check-circle.svg?raw';
import circleDollarSignIcon from 'lucide-static/icons/circle-dollar-sign.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';

const title = "Las Vegas Casino Injury Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"Hurt at a Las Vegas casino or resort? Eric Blank Injury Attorneys takes on casino legal teams and their insurers — 26+ years of experience. Free consultation. No fees unless we win. Call (702) 222-2115.";

const heroTrust = ["26+ Years", "Millions Recovered", "Available 24/7", "Free Consultation"];

const stats = [
	{ value: "Millions", label: "Recovered for Injury Victims" },
	{ value: "1000s", label: "of Injury Cases Handled" },
	{ value: "$0", label: "Out-of-Pocket Fees", note: "Contingency fee only" },
	{ value: "24/7", label: "Free Consultation" },
];

const steps = [
	{
		icon: shieldIcon,
		title: "Get To Safety",
		text: "If you can move, get out of the way of traffic — gaming floors, walkways, escalators, and pool decks can be crowded. If you suspect a serious injury, stay still and let security or EMS assess you first.",
	},
	{
		icon: clipboardListIcon,
		title: "Report It & Get The Incident Number",
		text: "Tell casino security or a manager what happened. Casinos document everything — ask for the incident report and, if possible, a copy before you leave. If they refuse, write down what you reported, to whom, and when.",
	},
	{
		icon: cameraIcon,
		title: "Photograph Everything",
		text: "Photograph the hazard, the location, your injuries, your clothing, and the surrounding area before anything is cleaned up. Casinos move fast on cleanup; what you don't capture in the first hour is often gone for good. Get names and numbers for any witnesses.",
	},
	{
		icon: stethoscopeIcon,
		title: "See A Doctor",
		text: "Casino-floor injuries are often more serious than they look — adrenaline hides head, neck, back, and internal injuries that surface days later. Get evaluated immediately and follow every treatment recommendation.",
	},
	{
		icon: banIcon,
		title: "Don't Sign Anything",
		text: "Casinos and their insurers often try to get statements, releases, or broad medical-authorization forms right at the scene or within hours. Don't sign anything — and don't give a recorded statement — until a lawyer has reviewed it.",
	},
	{
		icon: scaleIcon,
		title: "Call An Attorney First",
		text: "Casino surveillance footage is constant — and routinely overwritten. The faster a lawyer sends a preservation letter, the more evidence survives for your case.",
	},
];

const howWeHelp = [
	{
		icon: searchIcon,
		title: "Investigate The Premises",
		text: "We move fast on surveillance footage, incident reports, maintenance and inspection logs, prior similar incidents, and witness statements. Casino properties generate a tremendous amount of evidence — most of it controlled by the property and overwritten quickly without a preservation letter.",
	},
	{
		icon: clipboardListIcon,
		title: "Build The Medical Record",
		text: "Casino-floor and resort injuries are often serious — TBIs from falls, back and neck injuries, broken bones, complications from inadequate response. We work with your doctors to document every injury, current and future, so the casino's insurer can't minimize the harm.",
	},
	{
		icon: handshakeIcon,
		title: "Negotiate With Casino Insurers",
		text: "Vegas casinos use sophisticated in-house and outside defense teams. Eric Blank's insurance-defense background tells us where they cut corners and how their adjusters value claims — and we use that to push for a real number.",
	},
	{
		icon: gavelIcon,
		title: "Try The Case If Needed",
		text: "Casinos settle harder when they know your attorney is willing and able to try the case. We prepare every casino case as if it's going in front of a jury.",
	},
];

const economicDamages = [
	"Medical bills — past and future treatment",
	"Lost wages and reduced future earning capacity",
	"Property damage (broken phone, glasses, clothing)",
	"Out-of-pocket costs — transportation, prescriptions, and more",
];

const nonEconomicDamages = [
	"Pain and suffering",
	"Emotional distress",
	"Loss of enjoyment of life",
	"Permanent disability or disfigurement",
	"Loss of consortium",
];

const nevadaLaws = [
	{
		icon: calendarClockIcon,
		title: "Statute of Limitations",
		text: "Nevada gives you 2 years from the date of the injury to file a casino premises liability lawsuit (NRS 11.190). Miss that deadline and your claim is gone — and surveillance footage almost always cycles out long before then.",
	},
	{
		icon: scaleIcon,
		title: "Comparative Negligence",
		text: "Nevada follows a modified comparative negligence rule. If you are 51% or more at fault you recover nothing; if you are partly at fault but under that, your recovery is reduced by your share.",
	},
	{
		icon: shieldCheckIcon,
		title: "Casino Duty Of Care",
		text: "Nevada casinos and resorts owe their highest duty of care to business invitees — paying customers and registered guests. That generally means a duty to regularly inspect the property, correct hazards or warn about them, hire adequate security, and protect guests from foreseeable harm. Whether they breached that duty is the central question in most casino-injury cases.",
	},
];

const faqs = [
	{
		q: "Can I sue a Las Vegas casino if I'm hurt on the property?",
		a: "Yes, when negligence on the casino's part caused the injury. Nevada casinos and resorts owe their highest duty of care to business invitees. If they failed to fix or warn about a hazard, failed to provide adequate security, or otherwise breached that duty, you can pursue a claim — even though casinos bring an aggressive defense apparatus to every case.",
	},
	{
		q: "What about the incident report and release forms casino security gave me?",
		a: "Don't sign broad releases or medical authorizations without talking to a lawyer. Incident reports are useful — get a copy if you can — but releases and authorizations often give the casino's defense team access far beyond what's relevant to your injury, and can be used to reduce or deny your claim.",
	},
	{
		q: "What if I had been drinking when I was hurt?",
		a: "Casinos and bars in Nevada have duties around serving guests, and drinking does not automatically bar your claim. Your level of fault, if any, is decided under Nevada's modified comparative negligence rule — you can still recover as long as you are 50% or less responsible.",
	},
	{
		q: "What kinds of casino injuries can I recover for?",
		a: "Slip and trip falls on gaming floors, escalator and elevator incidents, assaults connected to inadequate security, parking-garage attacks, pool and spa injuries, dropped objects, broken handrails, and more. Any injury caused by the casino's failure to maintain reasonably safe premises is potentially compensable.",
	},
	{
		q: "How long do I have to file a casino injury claim in Nevada?",
		a: "Two years from the date of the injury, under NRS 11.190. Don't wait — surveillance footage cycles fast, and casinos won't preserve it for you unless they're legally required to. Claims that touch government property can have much shorter notice deadlines.",
	},
	{
		q: "How much does it cost to hire a casino injury lawyer?",
		a: "Our fee is contingency-based — no upfront cost and no hourly billing. We only get paid if we win, and the fee is a percentage of your recovery, agreed to in writing before we start.",
	},
];

const contactReasons = [
	{ text: "Free, no-obligation case review", icon: checkCircleIcon },
	{ text: "No fees unless we win your case", icon: circleDollarSignIcon },
	{ text: "Available 24/7 — nights, weekends, holidays", icon: clockIcon },
];

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/practice-areas/casino-injuries#service",
			name: "Eric Blank Injury Attorneys — Casino & Resort Injury Representation",
			serviceType: "Casino & Resort Injury Legal Services",
			url: "https://ericblanklaw.com/practice-areas/casino-injuries",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			telephone: "+1-702-222-2115",
			priceRange: "Contingency Fee — No Fees Unless We Win",
			areaServed: ["Las Vegas", "Henderson", "North Las Vegas", "Boulder City", "Clark County", "Nevada"],
			address: {
				"@type": "PostalAddress",
				streetAddress: "7860 W Sahara Ave Ste. 110",
				addressLocality: "Las Vegas",
				addressRegion: "NV",
				postalCode: "89117",
				addressCountry: "US",
			},
			employee: { "@id": "https://ericblanklaw.com/#attorney" },
		},
		{
			"@type": "Attorney",
			"@id": "https://ericblanklaw.com/#attorney",
			name: "Eric R. Blank",
			jobTitle: "Personal Injury Attorney",
		},
		{
			"@type": "FAQPage",
			"@id": "https://ericblanklaw.com/practice-areas/casino-injuries#faq",
			mainEntity: faqs.map((faq) => ({
				"@type": "Question",
				name: faq.q,
				acceptedAnswer: { "@type": "Answer", text: faq.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/practice-areas/casino-injuries"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- SECTION 1 — Hero -->
			<section class="bg-brand-navy text-white">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Las Vegas Casino Injuries
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						Las Vegas Casino Injury Attorney
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						Vegas casinos and resorts host enormous numbers of guests every day — and like
						any property open to the public, they owe those guests a real duty of safety.
						Slip-and-falls on gaming floors, escalator and elevator failures, parking-garage
						assaults, pool injuries, broken handrails, dropped objects — when a casino's
						negligence puts a guest in the hospital, they bring an aggressive defense team
						to the table. For over 26 years, Eric Blank Injury Attorneys has stood across
						from those teams. Free consultation, and no fees unless we win.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="#contact"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Free Case Review
						</a>
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
						>
							<span class="[&>svg]:size-5" set:html={phoneIcon} aria-hidden="true" />
							(702) 222-2115
						</a>
					</div>
					<ul class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:text-sm">
						{
							heroTrust.map((item, index) => (
								<li
									class:list={[
										index > 0 &&
											"before:mx-2 before:text-brand-gold before:content-['•'] sm:before:mx-3",
									]}
								>
									{item}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SECTION 2 — Trust strip -->
			<section class="border-b border-gray-200 bg-white">
				<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
					<dl class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
						{
							stats.map((stat) => (
								<div class="text-center">
									<dd class="text-3xl font-extrabold text-brand-navy sm:text-4xl">
										{stat.value}
									</dd>
									<dt class="mt-1 text-sm font-semibold text-gray-600">{stat.label}</dt>
									{stat.note && <p class="mt-0.5 text-xs text-gray-500">{stat.note}</p>}
								</div>
							))
						}
					</dl>
				</div>
			</section>

			<!-- SECTION 3 — What to do after a casino injury -->
			<section class="bg-white" aria-labelledby="steps-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							First Steps
						</p>
						<h2
							id="steps-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What To Do After A Casino Injury In Las Vegas
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							The first hours after the injury shape your entire claim. Here's how to
							protect yourself and your case.
						</p>
					</div>
					<ol class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
						{
							steps.map((step, index) => (
								<li class="rounded-lg border border-gray-200 bg-white p-6">
									<div class="flex items-center gap-3">
										<span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-navy text-sm font-bold text-brand-gold">
											{index + 1}
										</span>
										<span
											class="text-brand-navy [&>svg]:size-7"
											set:html={step.icon}
											aria-hidden="true"
										/>
									</div>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{step.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{step.text}
									</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- SECTION 4 — How we help -->
			<section class="bg-gray-50" aria-labelledby="help-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Our Approach
						</p>
						<h2
							id="help-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							How Eric Blank Injury Attorneys Handles Casino Injury Cases
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Eric Blank spent the early part of his career defending insurance companies.
							We bring that insider knowledge to every casino case — the same edge we
							apply across our{" "}
							<a
								href="/practice-areas"
								class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
							>
								personal injury practice
							</a>.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-4">
						{
							howWeHelp.map((item) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={item.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{item.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 5 — What you can recover -->
			<section class="bg-white" aria-labelledby="damages-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Damages
						</p>
						<h2
							id="damages-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What Casino Injury Victims Can Recover In Nevada
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Nevada law lets injury victims recover compensatory damages — both the
							concrete financial losses and the human cost of the incident. In rare cases
							involving especially reckless conduct, punitive damages may also apply.
						</p>
					</div>
					<div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									economicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Non-Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									nonEconomicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						Nevada caps damages in medical malpractice cases but <strong>not</strong> in
						general personal injury claims. The amount you can recover depends on the
						specifics of your case — a{" "}
						<a
							href="/contact"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
						>
							free consultation
						</a>{" "}
						is the best way to get a real answer.
					</p>
				</div>
			</section>

			<!-- SECTION 6 — Nevada law -->
			<section class="bg-gray-50" aria-labelledby="law-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Nevada Law
						</p>
						<h2
							id="law-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Key Nevada Casino Premises Liability Laws
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3 lg:mt-16">
						{
							nevadaLaws.map((law) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={law.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{law.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{law.text}
									</p>
								</div>
							))
						}
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						This is general information, not legal advice for your specific case. Talk to an
						attorney about the facts of your incident.
					</p>
				</div>
			</section>

			<!-- SECTION 7 — FAQ -->
			<section class="bg-white" aria-labelledby="faq-heading">
				<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
					<div class="text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							FAQ
						</p>
						<h2
							id="faq-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Common Casino Injury Questions
						</h2>
					</div>
					<div class="mt-10 space-y-8 lg:mt-12">
						{
							faqs.map((faq) => (
								<div>
									<h3 class="text-lg font-bold text-brand-navy sm:text-xl">{faq.q}</h3>
									<p class="mt-2 text-base leading-relaxed text-pretty text-gray-600">
										{faq.a}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 8 — Featured testimonial -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<figure>
						<span
							aria-hidden="true"
							class="mx-auto block w-fit text-brand-navy/60 [&>svg]:size-10"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-5 text-xl font-medium text-balance text-brand-navy sm:text-2xl">
							I had terrible injuries as a result of the accident I had and hiring Eric
							Blank to be on my side during this difficult process was the best thing I did.
						</blockquote>
						<figcaption class="mt-5 text-base font-bold text-brand-navy">— Tami</figcaption>
					</figure>
					<a
						href="/reviews"
						class="mt-8 inline-block text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
					>
						Read more client reviews →
					</a>
				</div>
			</section>

			<!-- SECTION 9 — Final CTA + contact form -->
			<section
				id="contact"
				class="scroll-mt-24 bg-brand-navy text-white"
				aria-labelledby="cta-heading"
			>
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<h2
							id="cta-heading"
							class="text-3xl font-bold tracking-tight text-balance sm:text-4xl"
						>
							Request Your Free Case Review
						</h2>
						<p class="mt-3 text-base text-pretty text-white/70 sm:text-lg">
							It's free, confidential, and there's no obligation.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
								Why Call Now
							</p>
							<h3 class="mt-3 text-xl font-bold sm:text-2xl">
								Three Reasons To Reach Out Today
							</h3>
							<ul class="mt-6 space-y-4">
								{
									contactReasons.map((reason) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={reason.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-white/90 sm:text-lg">{reason.text}</span>
										</li>
									))
								}
							</ul>
							<p class="mt-6 max-w-md text-base text-pretty text-white/70">
								Casino surveillance footage cycles fast — and casinos won't preserve it
								for you unless they're legally required to. The sooner we hear from you,
								the more we can do.
							</p>
						</div>
						<ContactForm />
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
