---
import '../../styles/global.css';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';

import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import shieldIcon from 'lucide-static/icons/shield.svg?raw';
import phoneCallIcon from 'lucide-static/icons/phone-call.svg?raw';
import cameraIcon from 'lucide-static/icons/camera.svg?raw';
import stethoscopeIcon from 'lucide-static/icons/stethoscope.svg?raw';
import banIcon from 'lucide-static/icons/ban.svg?raw';
import scaleIcon from 'lucide-static/icons/scale.svg?raw';
import searchIcon from 'lucide-static/icons/search.svg?raw';
import clipboardListIcon from 'lucide-static/icons/clipboard-list.svg?raw';
import handshakeIcon from 'lucide-static/icons/handshake.svg?raw';
import gavelIcon from 'lucide-static/icons/gavel.svg?raw';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import calendarClockIcon from 'lucide-static/icons/calendar-clock.svg?raw';
import shieldCheckIcon from 'lucide-static/icons/shield-check.svg?raw';
import quoteIcon from 'lucide-static/icons/quote.svg?raw';
import checkCircleIcon from 'lucide-static/icons/check-circle.svg?raw';
import circleDollarSignIcon from 'lucide-static/icons/circle-dollar-sign.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';

const title = "Las Vegas Slip and Fall Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"Hurt in a Las Vegas slip and fall? Eric Blank Injury Attorneys has handled premises liability cases for over 26 years. Free consultation. No fees unless we win. Call (702) 222-2115.";

const heroTrust = ["26+ Years", "Millions Recovered", "Available 24/7", "Free Consultation"];

const stats = [
	{ value: "Millions", label: "Recovered for Fall Victims" },
	{ value: "1000s", label: "of Slip-and-Fall Cases Handled" },
	{ value: "$0", label: "Out-of-Pocket Fees", note: "Contingency fee only" },
	{ value: "24/7", label: "Free Consultation" },
];

const steps = [
	{
		icon: shieldIcon,
		title: "Get To Safety",
		text: "If you can move, get yourself somewhere safe. If you suspect a serious head, neck, or back injury, stay still and ask for help — moving can make those injuries worse.",
	},
	{
		icon: clipboardListIcon,
		title: "Report It",
		text: "Tell the property manager, store manager, or owner what happened, and ask for a written incident report. Get a copy before you leave if you can. If they refuse, write down what you reported and to whom.",
	},
	{
		icon: cameraIcon,
		title: "Document The Hazard",
		text: "Photograph the floor, spill, broken tile, missing handrail, or whatever caused the fall — before it gets cleaned up or fixed. Capture multiple angles, your clothing, and any visible injuries. Get names and numbers for any witnesses.",
	},
	{
		icon: stethoscopeIcon,
		title: "See A Doctor",
		text: "Get evaluated even if you think you're just sore. Soft-tissue, back, and head injuries often surface days later. Gaps in treatment are the first thing carriers use to discount your claim.",
	},
	{
		icon: banIcon,
		title: "Don't Talk To Their Insurer",
		text: "Property owners and their insurers move fast — sometimes the same day. Don't give a recorded statement, sign a release, or accept a quick offer. Refer them to your lawyer.",
	},
	{
		icon: scaleIcon,
		title: "Call An Attorney First",
		text: "Surveillance footage and sweep logs are often the difference in a slip-and-fall case — and most of it is in the property owner's hands. The faster a lawyer sends a preservation letter, the more evidence survives.",
	},
];

const howWeHelp = [
	{
		icon: searchIcon,
		title: "Investigate The Premises",
		text: "We move fast to preserve evidence — surveillance footage, sweep and maintenance logs, prior incident reports, and witness statements. Most of this lives in the property owner's hands and gets overwritten quickly without a preservation letter.",
	},
	{
		icon: clipboardListIcon,
		title: "Build The Medical Record",
		text: "Slip-and-fall injuries are often layered — back, neck, knee, shoulder, head — and frequently develop over days or weeks. We work with your doctors to document every injury, current and future, so insurers can't minimize the harm.",
	},
	{
		icon: handshakeIcon,
		title: "Negotiate With Insurance",
		text: "Eric Blank spent years on the insurance-defense side. We know how premises-liability adjusters value claims and where they cut corners — and we use that knowledge to push for a real number.",
	},
	{
		icon: gavelIcon,
		title: "Try The Case If Needed",
		text: "Property owners and their carriers settle harder when they know your attorney is willing to put the case in front of a jury. We prepare every slip-and-fall case that way.",
	},
];

const economicDamages = [
	"Medical bills — past and future treatment",
	"Lost wages and reduced future earning capacity",
	"Property damage (broken glasses, phone, clothing)",
	"Out-of-pocket costs — transportation, prescriptions, and more",
];

const nonEconomicDamages = [
	"Pain and suffering",
	"Emotional distress",
	"Loss of enjoyment of life",
	"Permanent disability or disfigurement",
	"Loss of consortium",
];

const nevadaLaws = [
	{
		icon: calendarClockIcon,
		title: "Statute of Limitations",
		text: "Nevada gives you 2 years from the date of the fall to file a premises liability lawsuit (NRS 11.190). Claims against government entities — a fall on city or state property, for example — typically have much shorter notice deadlines, so don't wait.",
	},
	{
		icon: scaleIcon,
		title: "Comparative Negligence",
		text: "Nevada follows a modified comparative negligence rule. If you are 51% or more at fault you recover nothing; if you are partly at fault but under that, your recovery is reduced by your share.",
	},
	{
		icon: shieldCheckIcon,
		title: "Property Owner's Duty & Notice",
		text: "Under Nevada premises liability law, the duty a property owner owes you depends on whether you were an invitee, a licensee, or a trespasser — business invitees are owed the highest duty. To recover, you generally have to show the owner knew or should have known about the hazard — actual or constructive notice — and failed to fix it or warn you.",
	},
];

const faqs = [
	{
		q: "Who can be held liable for my slip and fall in Nevada?",
		a: "The party in control of the property at the time. Often that's a business owner, but it can also be a property-management company, a tenant, a maintenance contractor, or a landlord — and sometimes more than one. Identifying every party with coverage is part of our investigation.",
	},
	{
		q: "Do I have a case if the property owner says they didn't know about the hazard?",
		a: "Possibly yes. Nevada premises liability law also recognizes constructive notice — meaning the owner should have known about the hazard through reasonable inspection. A spill that's been on the floor long enough that a routine sweep would have caught it can satisfy that standard, even if no one actually saw it.",
	},
	{
		q: "What if the store says the fall was my fault?",
		a: "Carriers and property owners almost always argue some version of this. Nevada uses modified comparative negligence — you can still recover as long as you are 50% or less at fault, with your recovery reduced by your share. We've handled many cases where blame-shifting wasn't the obstacle the carrier tried to make it.",
	},
	{
		q: "How long do I have to file a slip and fall claim in Nevada?",
		a: "Two years from the date of the fall, under NRS 11.190. There are very few exceptions. Claims against government entities (a fall on city, county, or state property) typically have much shorter notice deadlines, so the sooner you speak with an attorney, the better.",
	},
	{
		q: "What kinds of evidence matter most in a slip and fall case?",
		a: "Surveillance video, sweep and maintenance logs, prior incident reports, photos of the hazard before it was cleaned up, the incident report you filed, and witness statements. Most of this is in the property owner's hands — we send preservation letters quickly to lock it down.",
	},
	{
		q: "How much does it cost to hire a slip and fall lawyer?",
		a: "Our fee is contingency-based — no upfront cost and no hourly billing. We only get paid if we win, and the fee is a percentage of your recovery, agreed to in writing before we start.",
	},
];

const contactReasons = [
	{ text: "Free, no-obligation case review", icon: checkCircleIcon },
	{ text: "No fees unless we win your case", icon: circleDollarSignIcon },
	{ text: "Available 24/7 — nights, weekends, holidays", icon: clockIcon },
];

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/practice-areas/slip-and-fall#service",
			name: "Eric Blank Injury Attorneys — Slip and Fall & Premises Liability Representation",
			serviceType: "Slip and Fall / Premises Liability Legal Services",
			url: "https://ericblanklaw.com/practice-areas/slip-and-fall",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			telephone: "+1-702-222-2115",
			priceRange: "Contingency Fee — No Fees Unless We Win",
			areaServed: ["Las Vegas", "Henderson", "North Las Vegas", "Boulder City", "Clark County", "Nevada"],
			address: {
				"@type": "PostalAddress",
				streetAddress: "7860 W Sahara Ave Ste. 110",
				addressLocality: "Las Vegas",
				addressRegion: "NV",
				postalCode: "89117",
				addressCountry: "US",
			},
			employee: { "@id": "https://ericblanklaw.com/#attorney" },
		},
		{
			"@type": "Attorney",
			"@id": "https://ericblanklaw.com/#attorney",
			name: "Eric R. Blank",
			jobTitle: "Personal Injury Attorney",
		},
		{
			"@type": "FAQPage",
			"@id": "https://ericblanklaw.com/practice-areas/slip-and-fall#faq",
			mainEntity: faqs.map((faq) => ({
				"@type": "Question",
				name: faq.q,
				acceptedAnswer: { "@type": "Answer", text: faq.a },
			})),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/practice-areas/slip-and-fall"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- SECTION 1 — Hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/slip-and-fall-hero.jpeg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Las Vegas Slip and Fall
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						Las Vegas Slip and Fall Attorney
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						From casino floors and hotel lobbies to grocery stores, restaurants, and
						apartment walkways — when a property owner doesn't fix a known hazard, the
						people they invite onto the property pay the price. Nevada puts a real duty on
						property owners to keep their premises reasonably safe, but proving that duty
						was breached takes work. For over 26 years, Eric Blank Injury Attorneys has
						handled premises liability claims across the Las Vegas valley. Free
						consultation, and no fees unless we win.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="#contact"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Free Case Review
						</a>
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-white/30 px-8 py-4 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10 sm:w-auto sm:text-lg"
						>
							<span class="[&>svg]:size-5" set:html={phoneIcon} aria-hidden="true" />
							(702) 222-2115
						</a>
					</div>
					<ul class="mx-auto mt-8 flex max-w-xl flex-wrap items-center justify-center gap-y-1 text-xs font-medium text-white/60 sm:text-sm">
						{
							heroTrust.map((item, index) => (
								<li
									class:list={[
										index > 0 &&
											"before:mx-2 before:text-brand-gold before:content-['•'] sm:before:mx-3",
									]}
								>
									{item}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- SECTION 2 — Trust strip -->
			<section class="border-b border-gray-200 bg-white">
				<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
					<dl class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-4">
						{
							stats.map((stat) => (
								<div class="text-center">
									<dd class="text-3xl font-extrabold text-brand-navy sm:text-4xl">
										{stat.value}
									</dd>
									<dt class="mt-1 text-sm font-semibold text-gray-600">{stat.label}</dt>
									{stat.note && <p class="mt-0.5 text-xs text-gray-500">{stat.note}</p>}
								</div>
							))
						}
					</dl>
				</div>
			</section>

			<!-- SECTION 3 — What to do after a fall -->
			<section class="bg-white" aria-labelledby="steps-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							First Steps
						</p>
						<h2
							id="steps-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What To Do After A Slip and Fall In Las Vegas
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							The first hours after a fall shape your entire claim. Here's how to protect
							yourself and your case.
						</p>
					</div>
					<ol class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
						{
							steps.map((step, index) => (
								<li class="rounded-lg border border-gray-200 bg-white p-6">
									<div class="flex items-center gap-3">
										<span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-brand-navy text-sm font-bold text-brand-gold">
											{index + 1}
										</span>
										<span
											class="text-brand-navy [&>svg]:size-7"
											set:html={step.icon}
											aria-hidden="true"
										/>
									</div>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{step.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{step.text}
									</p>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- SECTION 4 — How we help -->
			<section class="bg-gray-50" aria-labelledby="help-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Our Approach
						</p>
						<h2
							id="help-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							How Eric Blank Injury Attorneys Handles Slip and Fall Cases
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Eric Blank spent the early part of his career defending insurance companies.
							We bring that insider knowledge to every premises claim — the same edge we
							apply across our{" "}
							<a
								href="/practice-areas"
								class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
							>
								personal injury practice
							</a>.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:mt-16 lg:grid-cols-4">
						{
							howWeHelp.map((item) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={item.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{item.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 5 — What you can recover -->
			<section class="bg-white" aria-labelledby="damages-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Damages
						</p>
						<h2
							id="damages-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							What Slip and Fall Victims Can Recover In Nevada
						</h2>
						<p class="mt-4 text-base text-pretty text-gray-600 sm:text-lg">
							Nevada law lets injury victims recover compensatory damages — both the
							concrete financial losses and the human cost of the fall. In rare cases
							involving especially reckless conduct, punitive damages may also apply.
						</p>
					</div>
					<div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 lg:mt-16">
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									economicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
						<div class="rounded-lg border border-gray-200 bg-white p-8">
							<h3 class="text-xl font-bold text-brand-navy">Non-Economic Damages</h3>
							<ul class="mt-5 space-y-3">
								{
									nonEconomicDamages.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
												set:html={circleCheckIcon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						Nevada caps damages in medical malpractice cases but <strong>not</strong> in
						general personal injury claims. The amount you can recover depends on the
						specifics of your case — a{" "}
						<a
							href="/contact"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-2 transition-colors hover:decoration-brand-navy"
						>
							free consultation
						</a>{" "}
						is the best way to get a real answer.
					</p>
				</div>
			</section>

			<!-- SECTION 6 — Nevada law -->
			<section class="bg-gray-50" aria-labelledby="law-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Nevada Law
						</p>
						<h2
							id="law-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Key Nevada Premises Liability Laws
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3 lg:mt-16">
						{
							nevadaLaws.map((law) => (
								<div class="rounded-lg border border-gray-200 bg-white p-6">
									<span
										class="block text-brand-navy [&>svg]:size-10"
										set:html={law.icon}
										aria-hidden="true"
									/>
									<h3 class="mt-4 text-lg font-bold text-brand-navy">{law.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-pretty text-gray-600">
										{law.text}
									</p>
								</div>
							))
						}
					</div>
					<p class="mx-auto mt-8 max-w-2xl text-center text-sm text-pretty text-gray-500">
						This is general information, not legal advice for your specific case. Talk to an
						attorney about the facts of your accident.
					</p>
				</div>
			</section>

			<!-- SECTION 7 — FAQ -->
			<section class="bg-white" aria-labelledby="faq-heading">
				<div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
					<div class="text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							FAQ
						</p>
						<h2
							id="faq-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							Common Slip and Fall Questions
						</h2>
					</div>
					<div class="mt-10 space-y-8 lg:mt-12">
						{
							faqs.map((faq) => (
								<div>
									<h3 class="text-lg font-bold text-brand-navy sm:text-xl">{faq.q}</h3>
									<p class="mt-2 text-base leading-relaxed text-pretty text-gray-600">
										{faq.a}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- SECTION 8 — Featured testimonial -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<figure>
						<span
							aria-hidden="true"
							class="mx-auto block w-fit text-brand-navy/60 [&>svg]:size-10"
							set:html={quoteIcon}
						/>
						<blockquote class="mt-5 text-xl font-medium text-balance text-brand-navy sm:text-2xl">
							I had terrible injuries as a result of the accident I had and hiring Eric
							Blank to be on my side during this difficult process was the best thing I did.
						</blockquote>
						<figcaption class="mt-5 text-base font-bold text-brand-navy">— Tami</figcaption>
					</figure>
					<a
						href="/reviews"
						class="mt-8 inline-block text-sm font-semibold text-brand-navy transition-colors hover:text-brand-gold"
					>
						Read more client reviews →
					</a>
				</div>
			</section>

			<!-- SECTION 9 — Final CTA + contact form -->
			<section
				id="contact"
				class="scroll-mt-24 bg-brand-navy text-white"
				aria-labelledby="cta-heading"
			>
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="mx-auto max-w-2xl text-center">
						<h2
							id="cta-heading"
							class="text-3xl font-bold tracking-tight text-balance sm:text-4xl"
						>
							Request Your Free Case Review
						</h2>
						<p class="mt-3 text-base text-pretty text-white/70 sm:text-lg">
							It's free, confidential, and there's no obligation.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
								Why Call Now
							</p>
							<h3 class="mt-3 text-xl font-bold sm:text-2xl">
								Three Reasons To Reach Out Today
							</h3>
							<ul class="mt-6 space-y-4">
								{
									contactReasons.map((reason) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={reason.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-white/90 sm:text-lg">{reason.text}</span>
										</li>
									))
								}
							</ul>
							<p class="mt-6 max-w-md text-base text-pretty text-white/70">
								Surveillance footage and sweep logs are often the difference in a
								slip-and-fall case — and they can be overwritten within days. The sooner
								we hear from you, the more we can do.
							</p>
						</div>
						<ContactForm />
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
