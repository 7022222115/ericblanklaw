---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import PracticeAreaGrid from '../components/PracticeAreaGrid.astro';
---

<html lang="en">
	<head>
		<BaseHead
			title="Las Vegas Personal Injury Practice Areas | Eric Blank Injury Attorneys"
			description="Eric Blank Injury Attorneys handles car accidents, motorcycle accidents, slip and fall, dog bites, workers' comp, and more throughout Las Vegas and Clark County. Free consultation. (702) 222-2115."
			canonical="https://ericblanklaw.com/practice-areas"
		/>
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- A: page hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/practice-areas-hero.jpg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Practice Areas
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						How We Help Injured People in Las Vegas
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						From car accidents to wrongful death cases, our firm handles a broad range of
						personal injury matters across Clark County. If you've been hurt, we'll help
						you understand your options.
					</p>
				</div>
			</section>

			<!-- B: full practice areas grid -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							12 Areas of Focus
						</p>
						<h2 class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl">
							Personal Injury Cases We Handle
						</h2>
					</div>
					<div class="mt-12 lg:mt-16">
						<PracticeAreaGrid gridClass="grid grid-cols-2 gap-5 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4" />
					</div>
				</div>
			</section>

			<!-- C: don't see your case -->
			<section class="bg-white">
				<div class="mx-auto max-w-2xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<h2 class="text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl">
						Don't See Your Type of Case?
					</h2>
					<p class="mt-4 text-base leading-relaxed text-pretty text-gray-600 sm:text-lg">
						We handle many types of personal injury cases beyond what's listed here —
						including products liability, mass tort, school bullying, and dangerous product
						claims. If you're not sure whether you have a case, the easiest thing to do is
						ask. Initial consultations are always free.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
						<a
							href="tel:7022222115"
							class="inline-flex w-full items-center justify-center rounded-md bg-brand-gold px-8 py-4 text-base font-bold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:w-auto sm:text-lg"
						>
							Call (702) 222-2115
						</a>
						<a
							href="mailto:intake@ericblanklaw.com"
							class="font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-4 transition-colors hover:decoration-brand-navy"
						>
							intake@ericblanklaw.com
						</a>
					</div>
				</div>
			</section>

			<!-- D: contact form -->
			<Contact />
		</main>
		<Footer />
	</body>
</html>
