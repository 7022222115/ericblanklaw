---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import Lightbox from '../components/Lightbox.astro';
import circleCheckIcon from 'lucide-static/icons/circle-check.svg?raw';
import languagesIcon from 'lucide-static/icons/languages.svg?raw';
import houseIcon from 'lucide-static/icons/house.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';
import phoneIcon from 'lucide-static/icons/phone.svg?raw';

const differentiators = [
	{ text: "Free consultations on all personal injury cases", icon: circleCheckIcon },
	{ text: "Bilingual staff — Spanish speakers available", icon: languagesIcon },
	{ text: "Home and hospital visits available", icon: houseIcon },
	{ text: "Weekend and evening consultations", icon: clockIcon },
];

const team = [
	{
		name: "Eric R. Blank",
		title: "Founding Attorney",
		photo: "/Eric_Blank_01.jpg",
		initials: "ERB",
		bio: "With more than 26 years of experience, Eric began his career defending insurance companies before dedicating his practice entirely to injury victims. He now uses that insider knowledge to fight for the people those companies try to underpay.",
		bioUrl: "https://ericblanklaw.com/our-firm/eric-r-blank/",
	},
	{
		name: "Fikisha Miller",
		title: "Attorney",
		photo: null,
		initials: "FM",
		bio: "Fikisha Miller represents injury victims throughout the Las Vegas valley. [Bio details to be added.]",
		bioUrl: "https://ericblanklaw.com/our-firm/fikisha-miller/",
	},
	{
		name: "Robert T. Hernandez",
		title: "Attorney",
		photo: null,
		initials: "RTH",
		bio: "Robert T. Hernandez brings deep experience in personal injury litigation. [Bio details to be added.]",
		bioUrl: "https://ericblanklaw.com/our-firm/robert-t-hernandez/",
	},
];
---

<html lang="en">
	<head>
		<BaseHead
			title="About Eric Blank Injury Attorneys | Las Vegas Personal Injury Law Firm"
			description="Meet the Las Vegas personal injury attorneys at Eric Blank Injury Attorneys. Over 26 years of experience. Former insurance defense lawyer now fighting for injury victims. Call (702) 222-2115."
			canonical="https://ericblanklaw.com/about"
		/>
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- A: page hero -->
			<section class="relative bg-brand-navy text-white">
				<div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/about-hero.jpg')" aria-hidden="true"></div>
				<div class="absolute inset-0 bg-brand-navy/75" aria-hidden="true"></div>
				<div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:py-24">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						About Our Firm
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-5xl">
						Las Vegas Personal Injury Attorneys
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						For more than two decades, Eric Blank Injury Attorneys has fought for injury
						victims across Las Vegas and Clark County — from Henderson to Boulder City,
						Pahrump to Nye County. We've recovered significant verdicts and settlements for
						people seriously hurt by someone else's negligence, and built a reputation the
						insurance companies take seriously.
					</p>
				</div>
			</section>

			<!-- B: firm story -->
			<section class="bg-white">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
					<div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<div>
							<h2 class="text-3xl font-bold tracking-tight text-brand-navy sm:text-4xl">
								Why We Do This Work
							</h2>
							<div class="mt-6 space-y-4 text-base leading-relaxed text-pretty text-gray-600">
								<p>
									Eric Blank didn't start out representing injury victims. He spent the
									early part of his career on the other side — working in insurance
									defense and serving as general counsel for local television affiliates.
								</p>
								<p>
									That experience changed how he practices law. He knows exactly how
									insurance companies evaluate claims, where they look for weaknesses, and
									the strategies they use to pay victims as little as possible.
								</p>
								<p>
									He also knows something most clients never hear: insurance companies
									weigh who is representing you when they decide whether to settle fairly
									or drag a case toward trial. The right firm changes the math.
								</p>
							</div>
						</div>
						<div class="rounded-2xl border border-brand-navy/15 bg-white p-8">
							<h3 class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
								What Sets Us Apart
							</h3>
							<ul class="mt-5 space-y-4">
								{
									differentiators.map((item) => (
										<li class="flex items-start gap-3">
											<span
												class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-6"
												set:html={item.icon}
												aria-hidden="true"
											/>
											<span class="text-base text-gray-700">{item.text}</span>
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- C: meet the team -->
			<section class="bg-gray-50" aria-labelledby="team-heading">
				<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
					<div class="mx-auto max-w-2xl text-center">
						<p class="text-sm font-semibold tracking-wider text-brand-navy uppercase">
							Your Legal Team
						</p>
						<h2
							id="team-heading"
							class="mt-3 text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl"
						>
							The Attorneys Fighting For You
						</h2>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3 lg:mt-16">
						{
							team.map((member) => (
								<article class="flex flex-col rounded-lg border border-gray-200 bg-white p-6">
									{member.photo ? (
										<img
											src={member.photo}
											alt={member.name}
											width="600"
											height="900"
											loading="lazy"
											class="aspect-[2/3] w-full rounded-lg object-cover object-top"
										/>
									) : (
										<div class="flex aspect-[2/3] w-full items-center justify-center rounded-lg bg-brand-navy">
											<span class="text-4xl font-extrabold tracking-wide text-brand-gold">
												{member.initials}
											</span>
										</div>
									)}
									<h3 class="mt-5 text-xl font-bold text-brand-navy">{member.name}</h3>
									<p class="mt-0.5 text-sm font-semibold tracking-wide text-brand-gold uppercase">
										{member.title}
									</p>
									<p class="mt-3 text-base leading-relaxed text-pretty text-gray-600">
										{member.bio}
									</p>
									<a
										href={member.bioUrl}
										class="mt-auto inline-flex items-center gap-1 pt-5 text-sm font-bold text-brand-navy transition-colors hover:text-brand-gold"
									>
										Read Full Bio
										<svg
											class="size-4"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M5 12h14" />
											<path d="m13 6 6 6-6 6" />
										</svg>
									</a>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<!-- D: CTA -->
			<section class="bg-brand-navy text-white">
				<div class="mx-auto max-w-3xl px-4 py-14 text-center sm:px-6 sm:py-16">
					<h2 class="text-3xl font-bold tracking-tight text-balance sm:text-4xl">
						Ready to Talk?
					</h2>
					<p class="mt-3 text-base text-white/70 sm:text-lg">
						Free consultation. No fees unless we win.
					</p>
					<a
						href="tel:7022222115"
						class="mt-7 inline-flex items-center gap-3 rounded-lg bg-brand-gold px-8 py-4 text-xl font-extrabold text-brand-navy transition-colors hover:bg-[#d1a63b] sm:text-2xl"
					>
						<span class="[&>svg]:size-6" set:html={phoneIcon} aria-hidden="true" />
						(702) 222-2115
					</a>
					<p class="mt-4 text-sm text-white/60">
						Or use the form below to{" "}
						<a
							href="#contact"
							class="font-semibold text-white underline decoration-brand-gold decoration-2 underline-offset-4 hover:text-brand-gold"
						>
							request a callback
						</a>.
					</p>
				</div>
			</section>

			<!-- E: contact form -->
			<!-- Video testimonial carousel -->
			<TestimonialCarousel />

			<Contact />
		</main>
		<Footer />
		<!-- Universal media lightbox (used by the carousel) -->
		<Lightbox />
	</body>
</html>
