---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import BetterValues from '../components/BetterValues.astro';
import MidPageCTA from '../components/MidPageCTA.astro';
import PracticeAreas from '../components/PracticeAreas.astro';
import AboutEric from '../components/AboutEric.astro';
import Results from '../components/Results.astro';
import Testimonials from '../components/Testimonials.astro';
import Badges from '../components/Badges.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title =
	"Las Vegas Personal Injury Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"Hurt in an accident? Eric Blank Injury Attorneys has fought Las Vegas insurance companies for over 26 years. Free consultation. No fees unless we win. Call (702) 222-2115.";

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "LegalService",
			"@id": "https://ericblanklaw.com/#legalservice",
			name: "Eric Blank Injury Attorneys",
			image: "https://ericblanklaw.com/Eric_Blank_Injury_Attorneys_Logo.png",
			url: "https://ericblanklaw.com",
			telephone: "+1-702-222-2115",
			email: "intake@ericblanklaw.com",
			description: description,
			address: {
				"@type": "PostalAddress",
				streetAddress: "7860 W Sahara Ave Ste. 110",
				addressLocality: "Las Vegas",
				addressRegion: "NV",
				postalCode: "89117",
				addressCountry: "US",
			},
			geo: {
				"@type": "GeoCoordinates",
				latitude: 36.1452971,
				longitude: -115.2629678,
			},
			areaServed: [
				"Las Vegas",
				"Henderson",
				"North Las Vegas",
				"Boulder City",
				"Pahrump",
				"Clark County",
				"Nye County",
				"Nevada",
			],
			priceRange: "Contingency Fee — No Fees Unless We Win",
			openingHoursSpecification: {
				"@type": "OpeningHoursSpecification",
				dayOfWeek: [
					"Monday",
					"Tuesday",
					"Wednesday",
					"Thursday",
					"Friday",
					"Saturday",
					"Sunday",
				],
				opens: "00:00",
				closes: "23:59",
			},
			sameAs: [
				"https://www.facebook.com/blanklawoffices/",
				"https://www.instagram.com/ericblankinjuryattorneys/",
				"https://twitter.com/eblanklaw",
				"https://www.youtube.com/channel/UC6IixC-tkWoS1B_c8MFaHYQ",
				"https://www.tiktok.com/@ericblankinjuryattorneys",
			],
		},
		{
			"@type": "Attorney",
			"@id": "https://ericblanklaw.com/#attorney",
			name: "Eric R. Blank",
			worksFor: { "@id": "https://ericblanklaw.com/#legalservice" },
			jobTitle: "Personal Injury Attorney",
			description:
				"A Las Vegas personal injury attorney who spent years defending insurance companies before dedicating his practice to representing injured plaintiffs.",
			url: "https://ericblanklaw.com/our-firm/eric-r-blank/",
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/"
			ogImage="/og-default.jpg"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<Hero />
			<BetterValues />
			<MidPageCTA />
			<PracticeAreas />
			<AboutEric />
			<Results />
			<Testimonials />
			<Badges />
			<Contact />
		</main>
		<Footer />
	</body>
</html>
