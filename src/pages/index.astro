---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import BetterValues from '../components/BetterValues.astro';
import MidPageCTA from '../components/MidPageCTA.astro';
import PracticeAreas from '../components/PracticeAreas.astro';
import AboutEric from '../components/AboutEric.astro';
import Results from '../components/Results.astro';
import Reviews from '../components/Reviews.astro';
import Badges from '../components/Badges.astro';
import Contact from '../components/Contact.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import Lightbox from '../components/Lightbox.astro';
import Footer from '../components/Footer.astro';
import { firmNode, attorneyNode } from '../data/firm';

const title =
	"Las Vegas Personal Injury Attorney | Eric Blank Injury Attorneys | (702) 222-2115";
const description =
	"Hurt in an accident? Eric Blank Injury Attorneys has fought Las Vegas insurance companies for over 26 years. Free consultation. No fees unless we win. Call (702) 222-2115.";

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{ ...firmNode, description },
		{ ...attorneyNode, description: "A Las Vegas personal injury attorney who spent years defending insurance companies before dedicating his practice to representing injured plaintiffs." },
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical="https://ericblanklaw.com/"
			ogImage="/og-default.jpg"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<Hero />
			<BetterValues />
			<MidPageCTA />
			<PracticeAreas />
			<AboutEric />
			<Results />
			<Reviews />
			<Badges />
			<!-- Video testimonial carousel -->
			<TestimonialCarousel />

			<Contact />
		</main>
		<Footer />
		<!-- Universal media lightbox (used by the carousel) -->
		<Lightbox />
	</body>
</html>
