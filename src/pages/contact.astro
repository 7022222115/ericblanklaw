---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import Lightbox from '../components/Lightbox.astro';
import phoneIcon from 'lucide-static/icons/phone.svg?raw';
import mailIcon from 'lucide-static/icons/mail.svg?raw';
import mapPinIcon from 'lucide-static/icons/map-pin.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';

const mapsHref =
	"https://www.google.com/maps/place/Eric+Blank+Injury+Attorneys/@36.1452971,-115.2629678";
---

<html lang="en">
	<head>
		<BaseHead
			title="Contact Eric Blank Injury Attorneys | Las Vegas (702) 222-2115"
			description="Contact Eric Blank Injury Attorneys in Las Vegas for a free personal injury consultation. Open 24/7. Call (702) 222-2115 or use our online form. 7860 W Sahara Ave Ste. 110."
			canonical="https://ericblanklaw.com/contact"
		/>
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- A: small hero -->
			<section class="bg-brand-navy text-white">
				<div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 sm:py-16">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Get In Touch
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl">
						Free Consultation. No Fees Unless We Win.
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						Reach out by phone, email, or the form below. We respond within one business
						day — usually sooner.
					</p>
				</div>
			</section>

			<!-- B: contact info + form -->
			<section class="bg-white">
				<div class="mx-auto max-w-[1200px] px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
					<div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-16">
						<!-- LEFT: office details -->
						<div>
							<h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">
								Our Las Vegas Office
							</h2>
							<ul class="mt-6 space-y-5">
								<li class="flex items-start gap-3">
									<span
										class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
										set:html={phoneIcon}
										aria-hidden="true"
									/>
									<a
										href="tel:7022222115"
										class="text-lg font-bold text-brand-navy transition-colors hover:text-brand-gold"
									>
										(702) 222-2115
									</a>
								</li>
								<li class="flex items-start gap-3">
									<span
										class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
										set:html={mailIcon}
										aria-hidden="true"
									/>
									<a
										href="mailto:intake@ericblanklaw.com"
										class="break-words text-gray-700 transition-colors hover:text-brand-navy"
									>
										intake@ericblanklaw.com
									</a>
								</li>
								<li class="flex items-start gap-3">
									<span
										class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
										set:html={mapPinIcon}
										aria-hidden="true"
									/>
									<address class="text-gray-700 not-italic">
										7860 W Sahara Ave Ste. 110<br />Las Vegas, NV 89117
									</address>
								</li>
								<li class="flex items-start gap-3">
									<span
										class="mt-0.5 shrink-0 text-brand-gold [&>svg]:size-5"
										set:html={clockIcon}
										aria-hidden="true"
									/>
									<span class="font-medium text-gray-700">Open 24/7</span>
								</li>
							</ul>
							<a
								href={mapsHref}
								target="_blank"
								rel="noopener"
								class="mt-6 block w-full max-w-[420px] transition hover:brightness-110"
							>
								<img
									src="/Map_Eric_Blank_Injury_Attorneys.png"
									alt="Map of Eric Blank Injury Attorneys office in Las Vegas"
									width="1196"
									height="728"
									loading="lazy"
									class="h-auto w-full rounded-lg"
								/>
							</a>
						</div>

						<!-- RIGHT: call-back form -->
						<ContactForm />
					</div>
				</div>
			</section>

			<!-- C: driving directions -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<h2 class="text-3xl font-bold tracking-tight text-balance text-brand-navy sm:text-4xl">
						How to Find Us
					</h2>
					<p class="mt-4 text-base leading-relaxed text-pretty text-gray-600 sm:text-lg">
						Our office is located in west Las Vegas at 7860 W. Sahara Ave., between Buffalo
						Drive and Cimarron Road. We're a 15-minute drive from the Las Vegas Strip and
						easily accessible from Henderson, Summerlin, and the Northwest.
					</p>
					<a
						href={mapsHref}
						target="_blank"
						rel="noopener"
						class="mx-auto mt-8 block w-full max-w-2xl transition hover:brightness-110"
					>
						<img
							src="/Map_Eric_Blank_Injury_Attorneys.png"
							alt="Map showing the location of Eric Blank Injury Attorneys in Las Vegas"
							width="1196"
							height="728"
							loading="lazy"
							class="h-auto w-full rounded-lg"
						/>
					</a>
				</div>
			</section>
		<!-- Video testimonial carousel -->
		<TestimonialCarousel />

		</main>
		<Footer />
		<!-- Universal media lightbox (used by the carousel) -->
		<Lightbox />
	</body>
</html>
