---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
	<head>
		<BaseHead
			title="Page Not Found | Eric Blank Injury Attorneys"
			description="The page you're looking for can't be found. Explore our practice areas or get in touch with our Las Vegas injury team."
			noindex={true}
		/>
	</head>
	<body class="overflow-x-clip">
		<Header />
		<main>
			<!-- Navy hero -->
			<section class="bg-brand-navy text-white">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<p class="text-sm font-semibold tracking-wider text-brand-gold uppercase">
						Error 404
					</p>
					<h1 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl">
						We couldn't find that page
					</h1>
					<p class="mx-auto mt-4 max-w-2xl text-base text-pretty text-white/70 sm:text-lg">
						The page you're looking for may have moved or no longer exists. Here are a few
						ways to get back on track.
					</p>
				</div>
			</section>

			<!-- Recovery links -->
			<section class="bg-gray-50">
				<div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
					<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
						<a
							href="/"
							class="rounded-lg border border-gray-200 bg-white px-6 py-5 text-base font-semibold text-brand-navy shadow-sm transition hover:border-brand-gold hover:text-brand-gold"
						>
							Home
						</a>
						<a
							href="/practice-areas/"
							class="rounded-lg border border-gray-200 bg-white px-6 py-5 text-base font-semibold text-brand-navy shadow-sm transition hover:border-brand-gold hover:text-brand-gold"
						>
							Practice Areas
						</a>
						<a
							href="/contact/"
							class="rounded-lg border border-gray-200 bg-white px-6 py-5 text-base font-semibold text-brand-navy shadow-sm transition hover:border-brand-gold hover:text-brand-gold"
						>
							Contact Us
						</a>
					</div>
					<p class="mt-10 text-base text-gray-600 sm:text-lg">
						Prefer to talk? Call us at
						<a
							href="tel:7022222115"
							class="font-bold text-brand-navy transition-colors hover:text-brand-gold"
						>
							(702) 222-2115
						</a>
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
